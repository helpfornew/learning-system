def compress_image_for_youdao(image_base64, max_size=800 * 1024):
    """压缩图片到指定大小以内（用于有道 API）

    有道 API 限制图片大小不超过 1MB,此函数将图片压缩到 800KB 以内。
    """
    try:
        from PIL import Image
        import io
        import base64

        # 解码 Base64 图片
        image_bytes = base64.b64decode(image_base64)
        img = Image.open(io.BytesIO(image_bytes))

        # 转为 RGB 模式（处理 RGBA 图片）
        if img.mode in ('RGBA', 'LA', 'P'):
            img = img.convert('RGB')

        original_size = len(image_bytes)

        # 方法 1：降低质量压缩
        quality = 85
        while quality >= 10:
            buffer = io.BytesIO()
            img.save(buffer, format='JPEG', quality=quality, optimize=True)
            size = buffer.tell()
            if size <= max_size:
                print(f"[图片压缩] 质量={quality}, 大小={size/1024:.1f}KB (原始={original_size/1024:.1f}KB, 压缩比={size/original_size*100:.1f}%)")
                return base64.b64encode(buffer.getvalue()).decode('utf-8')
            quality -= 5

        # 方法 2：缩小尺寸 + 降低质量
        print("[图片压缩] 降低质量不够，开始缩小尺寸...")
        original_width, original_height = img.size  # 保存原始尺寸
        img = Image.open(io.BytesIO(image_bytes))  # 重新加载
        if img.mode in ('RGBA', 'LA', 'P'):
            img = img.convert('RGB')
        
        # 尝试不同缩放比例
        for scale in [0.5, 0.4, 0.3, 0.25, 0.2, 0.15]:
            new_w = int(original_width * scale)
            new_h = int(original_height * scale)
            img_small = img.resize((new_w, new_h), Image.Resampling.LANCZOS)
            
            quality = 80
            while quality >= 30:
                buffer = io.BytesIO()
                img_small.save(buffer, format='JPEG', quality=quality, optimize=True)
                size = buffer.tell()
                if size <= max_size:
                    print(f"[图片压缩] 成功！尺寸={new_w}x{new_h}, 质量={quality}, 大小={size/1024:.1f}KB")
                    return base64.b64encode(buffer.getvalue()).decode('utf-8')
                quality -= 10

        # 无法压缩，返回最小尺寸图片（不是原始图片）
        print(f"[图片压缩] 警告：无法压缩到{max_size / 1024:.0f}KB 以内，返回最低质量图片")
        # 使用最低质量重新压缩
        quality = 5
        buffer = io.BytesIO()
        img.save(buffer, format='JPEG', quality=quality, optimize=True)
        return base64.b64encode(buffer.getvalue()).decode('utf-8')

    except ImportError:
        print("[图片压缩] 警告：Pillow 未安装,跳过压缩")
        return image_base64
    except Exception as e:
        print(f"[图片压缩] 警告：压缩失败 - {e}")
        return image_base64


def handle_youdao_segment_handler(handler, data):
    """有道智云题目智能切割 API 处理函数

    根据官方文档 (请求要点.txt):
    - q: Base64 编码的图片（必填）
    - imageType: 图片类型,1-单题,2-多题,3-整页（必填）
    - appKey: 应用 ID（必填）
    - salt: 随机 UUID（必填）
    - curtime: 当前时间戳（秒）（必填）
    - signType: 签名版本,固定为 'v3'（必填）
    - sign: SHA256(appKey + getInput(q) + salt + curtime + appSecret)（必填）
    - docType: 响应类型,固定为 'json'（必填）
    """
    try:
        import base64
        import hashlib
        import time
        import uuid

        image_data = data.get('image', '')

        print(f"[YoudaoAPI] 有道 API 收到请求,图片数据长度：{len(image_data) if image_data else 0}")

        if not image_data:
            handler.send_json({'success': False, 'message': '缺少图片数据'})
            return

        # 移除 base64 前缀
        if 'base64,' in image_data:
            image_data = image_data.split('base64,')[1]
            print(f"[YoudaoAPI] 移除 base64 前缀后数据长度：{len(image_data)}")

        # 确保 image_data 是 UTF-8 编码的字符串
        if isinstance(image_data, bytes):
            image_data = image_data.decode('utf-8')

        # 确保是标准 base64（移除可能的换行符）
        image_data = image_data.replace('\n', '').replace('\r', '').replace(' ', '')

        # 压缩图片（有道 API 限制图片大小不超过 1MB）
        print(f"[YoudaoAPI] 原始图片 Base64 长度：{len(image_data)} (约{len(image_data)*3/4/1024:.1f}KB)")
        image_data = compress_image_for_youdao(image_data, max_size=800 * 1024)
        print(f"[YoudaoAPI] 压缩后图片 Base64 长度：{len(image_data)} (约{len(image_data)*3/4/1024:.1f}KB)")

        # 如果有道 API 密钥未配置,返回空结果（前端将使用手动模式）
        if not YOUDAO_APP_SECRET:
            print("[YoudaoAPI] 有道 API 未配置,返回空切割结果")
            handler.send_json({
                'success': True,
                'segments': [],
                'message': '有道 API 未配置,请手动框选',
                'needManualCrop': True
            })
            return

        # 生成鉴权参数
        salt = str(uuid.uuid1())  # 随机 UUID
        cur_time = str(int(time.time()))  # 当前时间戳（秒）

        # 计算签名：sign = sha256(appKey + getInput(q) + salt + curtime + appSecret)
        # getInput 规则：长度<=20 返回原值,>20 返回 前 10 位 + 长度 + 后 10 位
        def get_input(s):
            if len(s) <= 20:
                return s
            return s[:10] + str(len(s)) + s[-10:]

        sign_str = YOUDAO_APP_ID + get_input(image_data) + salt + cur_time + YOUDAO_APP_SECRET
        sign = hashlib.sha256(sign_str.encode('utf-8')).hexdigest()

        # 构建请求参数
        params = {
            'q': image_data,         # Base64 编码的图片（必填）
            'imageType': '1',        # 固定为 1（切题服务仅支持此值）
            'docType': 'json',       # 返回格式（必填）
            'appKey': YOUDAO_APP_ID, # 应用 ID（必填）
            'salt': salt,            # 随机 UUID（必填）
            'curtime': cur_time,     # 当前时间戳,秒级（必填）
            'signType': 'v3',        # 签名版本,固定为 v3（必填）
            'sign': sign,            # SHA256 签名（必填）
        }

        print(f"[YoudaoAPI] 签名字符串构成：appKey={YOUDAO_APP_ID[:8]}... + getInput(q) + salt={salt[:8]}... + curtime={cur_time} + appSecret")
        print(f"[YoudaoAPI] getInput 输入长度={len(image_data)}, 输出长度={len(get_input(image_data))}")
        print(f"[YoudaoAPI] 计算得到的签名：{sign}")

        # 构建请求
        url = 'https://openapi.youdao.com/cut_question'
        headers = {'Content-Type': 'application/x-www-form-urlencoded'}

        print(f"[YoudaoAPI] 发送请求到有道 API: {url}")
        response = requests.post(url, data=params, headers=headers, timeout=30)

        if response.status_code == 200:
            result = response.json()
            print(f"[YoudaoAPI] 有道 API 返回：errorCode={result.get('errorCode', '')}")
            error_code = result.get('errorCode', '')

            if error_code == '0':
                # 解析切割结果 - 有道 API 返回的是 Result (大写 R)
                result_data = result.get('Result') or result.get('result') or {}
                regions = result_data.get('regions', [])
                print(f"[YoudaoAPI] 识别到 {len(regions)} 个题目区域")
                segments = []

                for region in regions:
                    # boundingBox 格式：x1,y1,x2,y2,x3,y3,x4,y4（左上、右上、右下、左下）
                    bounding_box = region.get('boundingBox', '')
                    if bounding_box:
                        coords = list(map(int, bounding_box.split(',')))
                        if len(coords) >= 8:
                            # 计算边界框
                            x1, y1 = coords[0], coords[1]  # 左上
                            x2, y2 = coords[2], coords[3]  # 右上
                            x3, y3 = coords[4], coords[5]  # 右下
                            x4, y4 = coords[6], coords[7]  # 左下
                            # 计算宽度和高度（使用左上和右下坐标）
                            width = abs(x2 - x1)
                            height = abs(y3 - y1)
                            segments.append({
                                'x': min(x1, x4),
                                'y': min(y1, y2),
                                'width': width,
                                'height': height,
                                'questionText': ''
                            })

                handler.send_json({
                    'success': True,
                    'segments': segments,
                    'message': f'识别到 {len(segments)} 道题目'
                })
            else:
                error_msg = get_youdao_error_message(error_code)
                print(f"[ERROR] 有道 API 错误码 {error_code}: {error_msg}")

                # 图片过大,自动重试压缩
                if error_code == '15002':
                    print("[YoudaoAPI] 图片过大,尝试重新压缩...")
                    # 已经在上面压缩过了,这里直接返回手动模式
                    handler.send_json({
                        'success': True,
                        'segments': [],
                        'message': f'图片过大,请尝试裁剪后重新上传或使用手动框选功能',
                        'needManualCrop': True
                    })
                # 时间戳无效,可能是系统时间未同步
                elif error_code == '206':
                    print("[YoudaoAPI] 时间戳无效,请检查系统时间是否同步")
                    handler.send_json({
                        'success': False,
                        'message': '时间戳验证失败,请联系管理员同步服务器时间',
                        'segments': []
                    })
                # 签名验证失败
                elif error_code == '202':
                    print("[YoudaoAPI] 签名验证失败,检查 API 密钥配置")
                    handler.send_json({
                        'success': False,
                        'message': '签名验证失败,请检查有道 API 密钥配置',
                        'segments': []
                    })
                # 其他参数错误,返回手动模式
                elif error_code in ['101', '201', '203', '204', '205', '12001', '12002', '12004', '12005']:
                    handler.send_json({
                        'success': True,
                        'segments': [],
                        'message': f'智能识别失败：{error_msg},请使用手动框选功能',
                        'needManualCrop': True
                    })
                # 其他错误
                else:
                    handler.send_json({
                        'success': False,
                        'message': f'有道 API 错误：{error_msg}',
                        'segments': []
                    })
        else:
            print(f"[ERROR] 有道 API 请求失败：{response.status_code}")
            print(f"[ERROR] 响应内容：{response.text[:500] if response.text else '无'}")
            handler.send_json({
                'success': False,
                'message': f'有道 API 请求失败：{response.status_code}',
                'segments': []
            })

    except requests.exceptions.RequestException as e:
        print(f"[ERROR] 有道 API 网络请求错误：{str(e)}")
        handler.send_json({
            'success': False,
            'message': '有道 API 网络请求错误：' + str(e),
            'segments': []
        })
    except Exception as e:
        print(f"[ERROR] 有道 API 处理错误：{str(e)}")
        import traceback
        traceback.print_exc()
        handler.send_json({
            'success': False,
            'message': '有道 API 处理错误：' + str(e),
            'segments': []
        })


# ============ HTTP 请求处理 ============

class UnifiedHandler(BaseHTTPRequestHandler):
    """统一 HTTP 请求处理器"""

    def send_json(self, data, status=200):
        """发送 JSON 响应"""
        body = json.dumps(data, ensure_ascii=False, indent=2).encode('utf-8')
        self.send_response(status)
        self.send_header('Content-Type', 'application/json; charset=utf-8')
        self.send_header('Content-Length', len(body))
        # CORS 配置：生产环境应该限制具体域名
        # 更严格的CORS设置,支持指定域名
        allowed_origin = os.environ.get('ALLOWED_ORIGIN', '*')
        self.send_header('Access-Control-Allow-Origin', allowed_origin)
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Requested-With')
        self.send_header('Access-Control-Allow-Credentials', 'true')
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, content, status=200):
        """发送 HTML 响应"""
        body = content.encode('utf-8') if isinstance(content, str) else content
        self.send_response(status)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.send_header('Content-Length', len(body))
        self.end_headers()
        self.wfile.write(body)

    def send_static(self, file_path, content_type=None):
        """发送静态文件"""
        try:
            if file_path in STATIC_CACHE:
                content, cached_content_type = STATIC_CACHE[file_path]
                # 如果缓存中存在,使用缓存的content_type,除非调用者明确指定了一个新的
                if content_type is None:
                    content_type = cached_content_type
            else:
                with open(file_path, 'rb') as f:
                    content = f.read()

                # 如果没有指定content_type,根据文件扩展名确定
                if content_type is None:
                    _, ext = os.path.splitext(file_path.lower())

                    # 常见文件类型的MIME映射
                    mime_types = {
                        '.js': 'application/javascript',
                        '.css': 'text/css',
                        '.json': 'application/json',
                        '.html': 'text/html',
                        '.htm': 'text/html',
                        '.txt': 'text/plain',
                        '.xml': 'application/xml',
                        '.png': 'image/png',
                        '.jpg': 'image/jpeg',
                        '.jpeg': 'image/jpeg',
                        '.gif': 'image/gif',
                        '.svg': 'image/svg+xml',
                        '.ico': 'image/x-icon',
                        '.webp': 'image/webp',
                        '.bmp': 'image/bmp',
                        '.tiff': 'image/tiff',
                        '.tif': 'image/tiff',
                        '.pdf': 'application/pdf',
                        '.zip': 'application/zip',
                        '.tar': 'application/x-tar',
                        '.gz': 'application/gzip',
                        '.woff': 'font/woff',
                        '.woff2': 'font/woff2',
                        '.ttf': 'font/ttf',
                        '.eot': 'application/vnd.ms-fontobject'
                    }

                    content_type = mime_types.get(ext, 'application/octet-stream')

                STATIC_CACHE[file_path] = (content, content_type)

            self.send_response(200)
            self.send_header('Content-Type', content_type)
            self.send_header('Content-Length', len(content))
            self.send_header('Cache-Control', 'no-cache')
            self.end_headers()
            self.wfile.write(content)
        except FileNotFoundError:
            self.send_json({'error': 'File not found'}, 404)

    def require_auth(self):
        """需要认证的端点,返回 user_id 或 None
        从 Authorization 头中获取 token 进行验证
        如果没有 token,默认返回 admin 账户 (user_id=1)
        """
        auth_header = self.headers.get('Authorization', '')

        if not auth_header:
            # 尝试从 URL 参数获取 token（兼容旧版本）
            parsed = urlparse(self.path)
            params = parse_qs(parsed.query)
            token = params.get('token', [None])[0]
        else:
            # 从 Authorization: Bearer <token> 中获取
            parts = auth_header.split()
            if len(parts) == 2 and parts[0].lower() == 'bearer':
                token = parts[1]
            else:
                token = None

        if not token:
            # 没有 token 时,默认返回 admin 账户 (user_id=1)
            return 1

        result = verify_token(token)
        return result['user_id'] if result['valid'] else 1

    def do_OPTIONS(self):
        """处理 CORS 预检请求"""
        self.send_response(200)
        # 使用与send_json相同的CORS配置
        allowed_origin = os.environ.get('ALLOWED_ORIGIN', '*')
        self.send_header('Access-Control-Allow-Origin', allowed_origin)
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Requested-With')
        self.send_header('Access-Control-Allow-Credentials', 'true')
        self.send_header('Access-Control-Max-Age', '86400')
        self.end_headers()

    def do_GET(self):
        """处理 GET 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # ============ 路由匹配 ============

        # 1. 学习系统主页
        if path == '/' or path == '/index.html':
            self.serve_learning_home()
            return

        # 2. 工具中心页面
        if path == '/tools' or path == '/tools/' or path == '/tools.html':
            self.serve_tools_page()
            return

        # 3. 日程查看页面
        if path == '/schedule-view.html' or path == '/schedule-view/':
            self.serve_schedule_view_page()
            return

        # 3.5. 移动端主页
        if path == '/mobile.html' or path == '/mobile/':
            self.serve_mobile_page()
            return

        # 4. 错题系统前端
        if path.startswith('/mistake/') or path.startswith('/mistake-system/'):
            self.serve_mistake_frontend(path)
            return

        # 4. 静态资源（CSS, JS, images 等）
        if path.startswith('/static/'):
            self.serve_static_resource(path)
            return

        # 5. API 路由 - 需要认证
        if path.startswith('/api/'):
            self.handle_api_get(path)
            return

        # 6. 账号 API
        if path.startswith('/account/'):
            self.handle_account_get(path)
            return

        # 404
        self.send_json({'error': 'Not Found'}, 404)

    def do_POST(self):
        """处理 POST 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # 检查请求体大小
        content_length = int(self.headers.get('Content-Length', 0))
        if content_length > MAX_CONTENT_LENGTH:
            self.send_json({
                'success': False,
                'message': f'请求体过大,最大支持 {MAX_CONTENT_LENGTH // 1024 // 1024}MB'
            }, 413)
            return

        # API 路由
        if path.startswith('/api/'):
            self.handle_api_post(path)
            return

        # 账号 API
        if path.startswith('/account/'):
            self.handle_account_post(path)
            return

        self.send_json({'error': 'Not Found'}, 404)

    def do_PUT(self):
        """处理 PUT 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # API 路由
        if path.startswith('/api/'):
            self.handle_api_put(path)
            return

        self.send_json({'error': 'Not Found'}, 404)

    def do_DELETE(self):
        """处理 DELETE 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # API 路由
        if path.startswith('/api/'):
            self.handle_api_delete(path)
            return

        self.send_json({'error': 'Not Found'}, 404)

    # ============ 学习系统主页 ============

    def serve_learning_home(self):
        """提供学习系统主页"""
        index_path = os.path.join(CONFIG_DIR, 'index.html')
        if os.path.exists(index_path):
            with open(index_path, 'r', encoding='utf-8') as f:
                content = f.read()
            # 修改 API 地址为统一端口
            content = content.replace(':8081', ':8080').replace(':3001', ':8080')
            self.send_html(content)
        else:
            self.send_html('<h1>学习系统主页未找到</h1>', 404)

    # ============ 工具中心页面 ============

    def serve_tools_page(self):
        """提供工具中心页面"""
        tools_path = os.path.join(CONFIG_DIR, 'tools.html')
        if os.path.exists(tools_path):
            with open(tools_path, 'r', encoding='utf-8') as f:
                content = f.read()
            self.send_html(content)
        else:
            self.send_html('<h1>工具中心页面未找到</h1>', 404)

    # ============ 日程查看页面 ============

    def serve_schedule_view_page(self):
        """提供日程查看页面"""
        schedule_path = os.path.join(CONFIG_DIR, 'schedule-view.html')
        if os.path.exists(schedule_path):
            with open(schedule_path, 'r', encoding='utf-8') as f:
                content = f.read()
            self.send_html(content)
        else:
            self.send_html('<h1>日程查看页面未找到</h1>', 404)

    # ============ 移动端主页 ============

    def serve_mobile_page(self):
        """提供移动端主页"""
        mobile_path = os.path.join(CONFIG_DIR, 'mobile.html')
        if os.path.exists(mobile_path):
            with open(mobile_path, 'r', encoding='utf-8') as f:
                content = f.read()
            # 修改 API 地址为统一端口
            content = content.replace(':8081', ':8080').replace(':3001', ':8080')
            self.send_html(content)
        else:
            self.send_html('<h1>移动端主页未找到</h1>', 404)

    # ============ 错题系统前端 ============

    def serve_mistake_frontend(self, path):
        """提供错题系统前端"""
        # 开发模式：代理到 Vite 开发服务器
        if DEV_MODE:
            self.proxy_to_vite(path)
            return

        # 生产模式：从 dist 目录提供静态文件
        # 解析路径,去掉查询参数和片段
        parsed = urlparse(path)
        path_without_query = parsed.path

        # 移除前缀
        if path_without_query.startswith('/mistake/'):
            sub_path = path_without_query[len('/mistake/'):]
        elif path_without_query.startswith('/mistake-system/'):
            sub_path = path_without_query[len('/mistake-system/'):]
        else:
            sub_path = path_without_query[1:]

        if sub_path == '' or sub_path == '/':
            sub_path = 'index.html'

        file_path = os.path.join(MISTAKE_FRONTEND_DIR, sub_path)

        # 安全检查：防止目录遍历攻击
        real_path = os.path.realpath(file_path)
        if not real_path.startswith(os.path.realpath(MISTAKE_FRONTEND_DIR)):
            self.send_json({'error': 'Forbidden'}, 403)
            return

        if os.path.exists(file_path):
            # 对于HTML文件,确保使用正确的MIME类型
            if file_path.lower().endswith('.html'):
                self.send_static(file_path, 'text/html')
            else:
                self.send_static(file_path)
        else:
            # SPA 回退到 index.html - 仅针对 HTML 页面请求
            # 对于静态资源（.js, .css, .png 等）返回 404
            _, ext = os.path.splitext(sub_path.lower())
            if ext in ['.js', '.css', '.json', '.png', '.jpg', '.jpeg', '.gif', '.svg', '.ico', '.webp', '.woff', '.woff2', '.ttf', '.eot']:
                # 静态资源文件不存在，返回 404
                self.send_json({'error': 'Not Found'}, 404)
            else:
                # HTML 页面请求，回退到 index.html（支持前端路由）
                index_path = os.path.join(MISTAKE_FRONTEND_DIR, 'index.html')
                if os.path.exists(index_path):
                    self.send_static(index_path, 'text/html')
                else:
                    self.send_json({'error': 'Not Found'}, 404)

    def proxy_to_vite(self, path):
        """代理请求到 Vite 开发服务器"""
        from urllib.parse import urlparse, parse_qs
        
        # 移除 /mistake/ 或 /mistake-system/ 前缀
        parsed = urlparse(path)
        path_without_query = parsed.path
        if path_without_query.startswith('/mistake/'):
            vite_path = path_without_query[len('/mistake/'):]
        elif path_without_query.startswith('/mistake-system/'):
            vite_path = path_without_query[len('/mistake-system/'):]
        else:
            vite_path = path_without_query[1:] if path_without_query.startswith('/') else path_without_query

        # 构建 Vite 服务器的 URL
        vite_url = f"{VITE_DEV_SERVER}/{vite_path}"
        if parsed.query:
            vite_url += f"?{parsed.query}"

        try:
            # 创建请求
            req = urllib.request.Request(vite_url)
            req.add_header('User-Agent', 'LearningSystem/1.0')

            # 发送请求到 Vite 服务器
            with urllib.request.urlopen(req, timeout=30) as response:
                content = response.read()
                status = response.status
                headers = response.headers

                # 获取 Content-Type
                content_type = headers.get('Content-Type', 'text/html')

                # 发送响应
                self.send_response(status)
                self.send_header('Content-Type', content_type)
                self.send_header('Content-Length', len(content))
                # 添加 CORS 头,允许热更新
                self.send_header('Access-Control-Allow-Origin', '*')
                self.end_headers()
                self.wfile.write(content)

        except urllib.error.HTTPError as e:
            if e.code == 404:
                # 404 时返回 index.html（SPA 回退）
                index_url = f"{VITE_DEV_SERVER}/"
                try:
                    with urllib.request.urlopen(index_url, timeout=30) as response:
                        content = response.read()
                        self.send_response(200)
                        self.send_header('Content-Type', 'text/html')
                        self.send_header('Content-Length', len(content))
                        self.send_header('Access-Control-Allow-Origin', '*')
                        self.end_headers()
                        self.wfile.write(content)
                except Exception:
                    self.send_html('<h1>Vite 开发服务器不可用</h1><p>请确保运行 <code>npm run dev</code></p>', 503)
            else:
                self.send_json({'error': str(e)}, e.code)
        except Exception as e:
            logger.error(f'代理到 Vite 失败：{e}')
            self.send_html(f"""
                <h1>开发模式错误</h1>
                <p>无法连接到 Vite 开发服务器：</p>
                <pre>{VITE_DEV_SERVER}</pre>
                <p>请确保：</p>
                <ol>
                    <li>在新终端运行：<code>cd mistake_system/mistake-system-desktop && npm run dev</code></li>
                    <li>检查 Vite 服务器是否在端口 5173 运行</li>
                </ol>
            """, 503)



    # ============ 静态资源 ============

    def serve_static_resource(self, path):
        """提供静态资源"""
        # 从 /static/xxx 提取文件路径
        sub_path = path[len('/static/'):]
        file_path = os.path.join(BASE_DIR, 'static', sub_path)

        if os.path.exists(file_path):
            self.send_static(file_path)
        else:
            self.send_json({'error': 'Not Found'}, 404)

    # ============ API 处理 ============

    def handle_api_get(self, path):
        """处理 API GET 请求"""
        parsed = urlparse(self.path)
        params = parse_qs(parsed.query)

        # 健康检查 - 不需要认证
        if path == '/api/health':
            self.send_json({'status': 'ok', 'time': datetime.datetime.now().isoformat()})
            return

        # 获取当前用户
        user_id = self.require_auth()

        if path == '/api/user':
            if user_id:
                conn = get_unified_db()
                cursor = conn.cursor()
                cursor.execute('SELECT id, username, email, vip_level, created_at FROM users WHERE id = ?', (user_id,))
                row = cursor.fetchone()
                conn.close()
                if row:
                    self.send_json({'success': True, 'user': dict(row)})
                else:
                    self.send_json({'success': False, 'message': '用户不存在'}, 404)
            else:
                self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        # 错题 API - 需要认证
        if path.startswith('/api/mistakes'):
            self.handle_mistakes_get(user_id, params)
            return

        # 学习时间 API
        if path.startswith('/api/study-time'):
            self.handle_study_time_get(user_id, params)
            return

        # 单词本 API - 每日单词
        if path.startswith('/api/vocabulary-daily'):
            self.handle_vocabulary_daily_get(user_id, params)
            return
        # 单词本 API
        if path.startswith('/api/vocabulary'):
            self.handle_vocabulary_get(user_id, params)
            return

        # 配置 API
        if path.startswith('/api/config'):
            self.handle_config_get(user_id)
            return

        # AI配置 API
        if path.startswith('/api/ai-config'):
            self.handle_ai_config_get(path, user_id)
            return

        # 计划 API
        if path.startswith('/api/schedule'):
            self.handle_schedule_get()
            return

        # 工具 API - 时间跟踪
        if path.startswith('/api/tools/time-tracker'):
            self.handle_tools_time_tracker_get(user_id, params)
            return

        # 工具 API - 智能提醒
        if path.startswith('/api/tools/reminder'):
            self.handle_tools_reminder_get(user_id, params)
            return

        # 工具 API - 数据备份
        if path.startswith('/api/tools/backup'):
            self.handle_tools_backup_get(user_id, params)
            return

        self.send_json({'error': 'Not Found'}, 404)

    def handle_api_post(self, path):
        """处理 API POST 请求"""
        # 获取请求体
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length).decode('utf-8') if content_length > 0 else '{}'

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            data = {}

        # 添加请求日志
        print(f"[API] POST {path} - 请求体：{body[:200] if body else '空'}...")

        # 获取当前用户
        user_id = self.require_auth()
        print(f"[API] 用户 ID: {user_id}")

        # 对于需要认证的API端点,如果用户未登录,则拒绝访问
        # 注意：配置API（如获取配置）可能对未登录用户开放,但设置配置需要登录
        if path.startswith('/api/config'):
            # 配置API的处理单独在这里,可能需要特殊处理
            self.handle_config_post(user_id, data)
            return

        # AI配置API
        if path.startswith('/api/ai-config'):
            # AI配置API需要登录验证
            if not user_id:
                self.send_json({'success': False, 'message': '未登录'}, 401)
                return
            self.handle_ai_config_post(path, user_id, data)
            return

        # AI分析API - 代理外部AI请求
        if path.startswith('/api/ai-analysis'):
            if not user_id:
                self.send_json({'success': False, 'message': '未登录'}, 401)
                return
            self.handle_ai_analysis_proxy(user_id, data)
            return


        # 错题 API
        if path.startswith('/api/mistakes'):
            self.handle_mistakes_post(user_id, data)
            return

        # 学习时间 API
        if path.startswith('/api/study-time'):
            self.handle_study_time_post(user_id, data)
            return

        # 单词本 API - 添加单词
        if path.startswith('/api/vocabulary'):
            self.handle_vocabulary_post(user_id, data)
            return

        # 单词复习 API
        if path.startswith('/api/vocabulary-review'):
            self.handle_vocabulary_review_post(user_id, data)
            return

        # 单词批量导入 API
        if path.startswith('/api/vocabulary-batch'):
            self.handle_vocabulary_batch_import_post(user_id, data)
            return

        # 工具 API - 时间跟踪
        if path.startswith('/api/tools/time-tracker'):
            self.handle_tools_time_tracker_post(user_id, data)
            return

        # 工具 API - 智能提醒
        if path.startswith('/api/tools/reminder'):
            self.handle_tools_reminder_post(user_id, data)
            return

        # 工具 API - 数据备份
        if path.startswith('/api/tools/backup'):
            self.handle_tools_backup_post(user_id, data)
            return

        # 有道智云 API - 题目智能切割（不需要登录验证）
        if path.startswith('/api/youdao/segment'):
            handle_youdao_segment_handler(self, data)
            return

        self.send_json({'error': 'Not Found'}, 404)

    def handle_api_put(self, path):
        """处理 API PUT 请求"""
        # 获取请求体
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length).decode('utf-8') if content_length > 0 else '{}'

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            data = {}

        # 获取当前用户
        user_id = self.require_auth()

        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        # 解析路径并路由到相应处理函数
        path_parts = path.strip('/').split('/')

        if len(path_parts) >= 2 and path_parts[0] == 'api' and path_parts[1] == 'mistakes':
            # 处理更新错题请求: /api/mistakes/{id}
            if len(path_parts) == 3:  # /api/mistakes/{id}
                try:
                    mistake_id = int(path_parts[2])
                    self.handle_mistakes_put(user_id, mistake_id, data)
                except ValueError:
                    self.send_json({'success': False, 'error': 'Invalid mistake ID'}, 400)
            else:
                self.send_json({'success': False, 'error': 'Invalid path'}, 400)
            return

        # 其他PUT API端点
        self.send_json({'success': False, 'error': 'Not Found'}, 404)

    def handle_api_delete(self, path):
        """处理 API DELETE 请求"""
        # 获取当前用户
        user_id = self.require_auth()

        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        # 解析路径并路由到相应处理函数
        path_parts = path.strip('/').split('/')

        if len(path_parts) >= 2 and path_parts[1] == 'mistakes':
            # 处理删除错题请求: /api/mistakes/{id}
            self.handle_mistakes_delete(user_id, path)
            return
        elif len(path_parts) >= 2 and path_parts[1] == 'study-time':
            # 处理删除学习时间记录请求: /api/study-time/{id}
            self.handle_study_time_delete(user_id, path)
            return
        elif len(path_parts) >= 2 and path_parts[1] == 'vocabulary':
            # 处理删除单词请求：/api/vocabulary/{id}
            self.handle_vocabulary_delete(user_id, path)
            return
        else:
            self.send_json({'error': 'Not Found'}, 404)

    # ============ 错题 API ============

    def handle_mistakes_get(self, user_id, params):
        """获取错题列表"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        conn = get_mistake_db()
        cursor = conn.cursor()

        # 按用户过滤（统一数据库中的mistakes表）
        cursor.execute('SELECT * FROM mistakes WHERE user_id = ? ORDER BY created_at DESC', (user_id,))
        rows = cursor.fetchall()
        conn.close()

        mistakes = [dict(row) for row in rows]
        self.send_json({'success': True, 'data': mistakes})

    def handle_mistakes_post(self, user_id, data):
        """创建或更新错题"""
        conn = get_mistake_db()
        cursor = conn.cursor()

        # 确保所有字段值都是适当类型
        def safe_str(val):
            if val is None:
                return ''
            elif isinstance(val, (list, dict)):
                return json.dumps(val, ensure_ascii=False)
            else:
                return str(val)

        # 创建新错题（使用统一数据库结构）
        cursor.execute('''
            INSERT INTO mistakes (user_id, subject_id, content, wrong_answer, correct_answer, error_reason, analysis,
                                  knowledge_points, tags, difficulty, images_path)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (user_id,
              int(data.get('subject_id', 1)),
              safe_str(data.get('content', '')),
              safe_str(data.get('wrong_answer', '')),
              safe_str(data.get('correct_answer', '')),
              safe_str(data.get('error_reason', '')),
              safe_str(data.get('analysis', '')),
              safe_str(data.get('knowledge_points', '')),
              safe_str(data.get('tags', '')),
              int(data.get('difficulty', 2)),
              safe_str(data.get('images_path', ''))))  # 添加 images_path 参数

        mistake_id = cursor.lastrowid
        conn.commit()
        conn.close()

        self.send_json({'success': True, 'id': mistake_id})

    def handle_mistakes_delete(self, user_id, path):
        """删除错题"""

        # 从路径中提取错题ID
        path_parts = path.strip('/').split('/')
        if len(path_parts) < 3:
            self.send_json({'success': False, 'message': '缺少错题ID'}, 400)
            return

        try:
            mistake_id = int(path_parts[2])  # /api/mistakes/{id}
        except ValueError:
            self.send_json({'success': False, 'message': '无效的错题ID'}, 400)
            return

        conn = get_mistake_db()
        cursor = conn.cursor()

        try:
            # 检查错题是否存在且属于当前用户
            cursor.execute('SELECT id FROM mistakes WHERE id = ? AND user_id = ?', (mistake_id, user_id))
            row = cursor.fetchone()

            if not row:
                self.send_json({'success': False, 'message': '错题不存在或无权限删除'}, 404)
                return

            # 删除错题
            cursor.execute('DELETE FROM mistakes WHERE id = ? AND user_id = ?', (mistake_id, user_id))
            conn.commit()

            self.send_json({'success': True, 'message': '错题删除成功'})
        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    def handle_mistakes_put(self, user_id, mistake_id, data):
        """更新错题"""
        conn = get_mistake_db()
        cursor = conn.cursor()

        try:
            # 检查错题是否存在且属于当前用户
            cursor.execute('SELECT id FROM mistakes WHERE id = ? AND user_id = ?', (mistake_id, user_id))
            row = cursor.fetchone()

            if not row:
                self.send_json({'success': False, 'message': '错题不存在或无权限更新'}, 404)
                return

            # 确保值是安全的类型
            def safe_str(val):
                if val is None:
                    return ''
                elif isinstance(val, (list, dict)):
                    return json.dumps(val, ensure_ascii=False)
                else:
                    return str(val)

            # 构建更新语句和参数
            update_fields = []
            update_values = []

            # 检查data中的字段,并将其添加到更新语句中
            for field in ['content', 'wrong_answer', 'correct_answer', 'error_reason', 'analysis',
                         'knowledge_points', 'tags', 'difficulty', 'images_path']:
                if field in data:
                    update_fields.append(f"{field} = ?")
                    update_values.append(safe_str(data[field]))

            if not update_fields:
                self.send_json({'success': False, 'message': '没有提供要更新的字段'}, 400)
                return

            # 添加用户ID和ID到参数末尾
            update_values.extend([user_id, mistake_id])

            # 执行更新
            sql = f"UPDATE mistakes SET {', '.join(update_fields)} WHERE user_id = ? AND id = ?"
            cursor.execute(sql, update_values)
            conn.commit()

            # 返回更新后的错题
            cursor.execute('SELECT * FROM mistakes WHERE id = ? AND user_id = ?', (mistake_id, user_id))
            updated_mistake = cursor.fetchone()

            if updated_mistake:
                self.send_json({'success': True, 'data': dict(updated_mistake)})
            else:
                self.send_json({'success': True, 'message': '错题更新成功'})

        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    # ============ 学习时间 API ============

    def handle_study_time_get(self, user_id, params):
        """获取学习时间统计"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        conn = get_study_db()
        cursor = conn.cursor()

        # 获取今日学习时间（统一数据库中的study_time表）
        today = datetime.datetime.now().strftime('%Y-%m-%d')
        cursor.execute('SELECT subject, SUM(duration) as total FROM study_time WHERE user_id = ? AND date = ? GROUP BY subject',
                       (user_id, today))
        rows = cursor.fetchall()
        conn.close()

        today_total = sum(row['total'] for row in rows)
        self.send_json({
            'success': True,
            'today': dict((r['subject'], r['total']) for r in rows),
            'today_total': today_total
        })

    def handle_study_time_post(self, user_id, data):
        """记录学习时间"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        subject = data.get('subject', '其他')
        duration = data.get('duration', 0)

        conn = get_study_db()
        cursor = conn.cursor()
        today = datetime.datetime.now().strftime('%Y-%m-%d')

        cursor.execute('''
            INSERT INTO study_time (user_id, subject, duration, date)
            VALUES (?, ?, ?, ?)
        ''', (user_id, subject, duration, today))

        conn.commit()
        conn.close()

        self.send_json({'success': True})

    def handle_study_time_delete(self, user_id, path):
        """删除学习时间记录"""
