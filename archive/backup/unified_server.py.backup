# ============ 日志配置 ============
def setup_logging():
    """配置日志系统"""
    level = getattr(logging, LOG_LEVEL.upper(), logging.INFO)
    log_dir = os.path.dirname(LOG_FILE_PATH)

    # 检查日志目录是否可写,如果不可写则使用备用路径
    log_file = LOG_FILE_PATH
    if log_dir and not os.path.exists(log_dir):
        try:
            os.makedirs(log_dir, exist_ok=True)
        except (PermissionError, OSError):
            # 降级到用户主目录
            home_log = os.path.join(os.path.expanduser('~'), '.learning-system', 'server.log')
            log_file = home_log
            log_dir = os.path.dirname(home_log)
            os.makedirs(log_dir, exist_ok=True)

    formatter = logging.Formatter(
        '%(asctime)s - %(name)s - %(levelname)s - %(message)s',
        datefmt='%Y-%m-%d %H:%M:%S'
    )

    logger = logging.getLogger('LearningSystem')
    logger.setLevel(level)
    logger.handlers = []

    # 尝试添加文件处理器
    try:
        if log_dir and os.access(os.path.dirname(log_file), os.W_OK):
            file_handler = RotatingFileHandler(
                log_file,
                maxBytes=10*1024*1024,
                backupCount=5,
                encoding='utf-8'
            )
            file_handler.setFormatter(formatter)
            logger.addHandler(file_handler)
            logger.info(f"日志文件：{log_file}")
    except (PermissionError, OSError) as e:
        logger.warning(f"无法写入日志文件 {log_file}: {e},将只输出到控制台")

    # 添加控制台处理器
    console_handler = logging.StreamHandler()
    console_handler.setFormatter(formatter)
    logger.addHandler(console_handler)

    return logger

logger = setup_logging()

