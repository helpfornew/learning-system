    # ============ 单词本 API ============

    def handle_vocabulary_get(self, user_id, params):
        """获取单词本列表"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        # 获取所有单词（按用户过滤）
        cursor.execute('SELECT * FROM vocabulary WHERE user_id = ? ORDER BY created_at DESC', (user_id,))
        rows = cursor.fetchall()
        conn.close()

        self.send_json({
            'success': True,
            'data': [dict(row) for row in rows]
        })

    def handle_vocabulary_daily_get(self, user_id, params):
        import random
        if not user_id:
            self.send_json({"success": False, "message": "未登录"}, 401)
            return
        daily_goal = int(params.get("goal", 10))
        conn = get_vocabulary_db()
        cursor = conn.cursor()
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        # Get review words
        cursor.execute("SELECT * FROM vocabulary WHERE user_id = ? AND status IN ('learning', 'reviewing') AND date(next_review) <= date(?)", (user_id, today))
        review_words = [dict(row) for row in cursor.fetchall()]
        # Get new words
        cursor.execute("SELECT * FROM vocabulary WHERE user_id = ? AND status = 'new' ORDER BY created_at ASC LIMIT ?", (user_id, daily_goal // 2))
        new_words = [dict(row) for row in cursor.fetchall()]
        # Fill with random words if needed
        total_needed = daily_goal - len(review_words) - len(new_words)
        if total_needed > 0:
            cursor.execute("SELECT * FROM vocabulary WHERE user_id = ? AND status != 'mastered' ORDER BY RANDOM() LIMIT ?", (user_id, total_needed))
            random_words = [dict(row) for row in cursor.fetchall()]
            new_words.extend(random_words)
        conn.close()
        today_words = review_words + new_words
        random.shuffle(today_words)
        self.send_json({"success": True, "data": {"words": today_words, "goal": daily_goal, "review_count": len(review_words), "new_count": len(new_words)}})

    def handle_vocabulary_post(self, user_id, data):
        """添加单词到单词本"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        word = data.get('word', '').strip()
        if not word:
            self.send_json({'success': False, 'message': '单词不能为空'}, 400)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        try:
            # 检查单词是否已存在
            cursor.execute('SELECT id FROM vocabulary WHERE user_id = ? AND word = ?', (user_id, word))
            if cursor.fetchone():
                self.send_json({'success': False, 'message': '单词已存在'}, 409)
                return

            # 插入新单词
            cursor.execute('''
                INSERT INTO vocabulary (user_id, word, phonetic, definition, example_sentence,
                                       example_translation, part_of_speech, tags, difficulty_level, status)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (
                user_id,
                word,
                data.get('phonetic', ''),
                data.get('definition', ''),
                data.get('example_sentence', ''),
                data.get('example_translation', ''),
                data.get('part_of_speech', ''),
                json.dumps(data.get('tags', []), ensure_ascii=False),
                data.get('difficulty_level', 1),
                data.get('status', 'new')
            ))

            conn.commit()
            self.send_json({'success': True, 'message': '单词添加成功'})
        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    def handle_vocabulary_put(self, user_id, vocabulary_id, data):
        """更新单词信息"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        try:
            # 检查单词是否存在且属于当前用户
            cursor.execute('SELECT id FROM vocabulary WHERE id = ? AND user_id = ?', (vocabulary_id, user_id))
            if not cursor.fetchone():
                self.send_json({'success': False, 'message': '单词不存在或无权限'}, 404)
                return

            # 更新单词信息
            cursor.execute('''
                UPDATE vocabulary
                SET phonetic = ?, definition = ?, example_sentence = ?,
                    example_translation = ?, part_of_speech = ?, tags = ?,
                    difficulty_level = ?, status = ?, 熟练度 = ?,
                    next_review = ?, review_count = ?, last_reviewed = ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = ? AND user_id = ?
            ''', (
                data.get('phonetic', ''),
                data.get('definition', ''),
                data.get('example_sentence', ''),
                data.get('example_translation', ''),
                data.get('part_of_speech', ''),
                json.dumps(data.get('tags', []), ensure_ascii=False),
                data.get('difficulty_level', 1),
                data.get('status', 'new'),
                data.get('熟练度', 0),
                data.get('next_review'),
                data.get('review_count', 0),
                data.get('last_reviewed'),
                vocabulary_id,
                user_id
            ))

            conn.commit()
            self.send_json({'success': True, 'message': '单词更新成功'})
        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    def handle_vocabulary_delete(self, user_id, path):
        """删除单词"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        path_parts = path.strip('/').split('/')
        if len(path_parts) < 3:
            self.send_json({'success': False, 'message': '缺少单词 ID'}, 400)
            return

        try:
            vocabulary_id = int(path_parts[2])
        except ValueError:
            self.send_json({'success': False, 'message': '无效的单词 ID'}, 400)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        try:
            cursor.execute('SELECT id FROM vocabulary WHERE id = ? AND user_id = ?', (vocabulary_id, user_id))
            if not cursor.fetchone():
                self.send_json({'success': False, 'message': '单词不存在或无权限删除'}, 404)
                return

            cursor.execute('DELETE FROM vocabulary WHERE id = ? AND user_id = ?', (vocabulary_id, user_id))
            conn.commit()
            self.send_json({'success': True, 'message': '单词删除成功'})
        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    def handle_vocabulary_review_post(self, user_id, data):
        """记录单词复习"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        vocabulary_id = data.get('vocabulary_id')
        result = data.get('result')  # 'correct' or 'wrong'
        response_time_ms = data.get('response_time_ms', 0)

        if not vocabulary_id:
            self.send_json({'success': False, 'message': '缺少单词 ID'}, 400)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        try:
            # 检查单词是否存在
            cursor.execute('SELECT * FROM vocabulary WHERE id = ? AND user_id = ?', (vocabulary_id, user_id))
            vocab_row = cursor.fetchone()
            if not vocab_row:
                self.send_json({'success': False, 'message': '单词不存在'}, 404)
                return

            # 更新单词状态
            current_time = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            new_review_count = vocab_row['review_count'] + 1

            # 根据结果计算下次复习时间
            if result == 'correct':
                # 答对了,增加熟练度,延长复习间隔
                new_熟练度 = min(vocab_row['熟练度'] + 1, 5)
                days_until_review = [1, 2, 4, 7, 14, 30][new_熟练度]
                next_review = (datetime.datetime.now() + datetime.timedelta(days=days_until_review)).strftime('%Y-%m-%d')
                status = 'mastered' if new_熟练度 >= 5 else 'reviewing'
            else:
                # 答错了,降低熟练度,缩短复习间隔
                new_熟练度 = max(vocab_row['熟练度'] - 1, 0)
                days_until_review = 1
                next_review = (datetime.datetime.now() + datetime.timedelta(days=days_until_review)).strftime('%Y-%m-%d')
                status = 'reviewing'

            cursor.execute('''
                UPDATE vocabulary
                SET 熟练度 = ?, review_count = ?, last_reviewed = ?,
                    next_review = ?, status = ?, updated_at = CURRENT_TIMESTAMP
                WHERE id = ? AND user_id = ?
            ''', (new_熟练度,new_review_count, current_time, next_review, status, vocabulary_id, user_id))

            # 记录学习行为
            cursor.execute('''
                INSERT INTO vocabulary_learning_record (user_id, vocabulary_id, action, result, response_time_ms)
                VALUES (?, ?, 'review', ?, ?)
            ''', (user_id, vocabulary_id, result, response_time_ms))

            conn.commit()
            self.send_json({'success': True, 'message': '复习记录成功'})
        except Exception as e:
            self.send_json({'success': False, 'message': str(e)})
        finally:
            conn.close()

    def handle_vocabulary_batch_import_post(self, user_id, data):
        """批量导入单词"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        words = data.get('words', [])
        if not words:
            self.send_json({'success': False, 'message': '单词列表不能为空'}, 400)
            return

        conn = get_vocabulary_db()
        cursor = conn.cursor()

        imported_count = 0
        skipped_count = 0

        for word_data in words:
            word = word_data.get('word', '').strip()
            if not word:
                continue

            try:
                # 检查是否已存在
                cursor.execute('SELECT id FROM vocabulary WHERE user_id = ? AND word = ?', (user_id, word))
                if cursor.fetchone():
                    skipped_count += 1
                    continue

                cursor.execute('''
                    INSERT INTO vocabulary (user_id, word, phonetic, definition, example_sentence,
                                           example_translation, part_of_speech, tags, status)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                ''', (
                    user_id,
                    word,
                    word_data.get('phonetic', ''),
                    word_data.get('definition', ''),
                    word_data.get('example_sentence', ''),
                    word_data.get('example_translation', ''),
                    word_data.get('part_of_speech', ''),
                    json.dumps(word_data.get('tags', []), ensure_ascii=False),
                    'new'
                ))
                imported_count += 1
            except Exception:
                skipped_count += 1
                continue

        conn.commit()
        conn.close()

        self.send_json({
            'success': True,
            'message': f'导入完成',
            'imported_count': imported_count,
            'skipped_count': skipped_count
        })

    # ============ 配置 API ============

    def handle_config_get(self, user_id):
        """获取用户配置（合并学习配置和AI配置）"""
        combined_config = {}

        conn = None
        try:
            # 获取学习配置
            if user_id:
                conn = get_unified_db()
                cursor = conn.cursor()

                # 获取学习配置
                cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'learning_config'))
                row = cursor.fetchone()
                if row and row[0]:
                    try:
                        learning_config = json.loads(row[0])
                        combined_config.update(learning_config)
                    except json.JSONDecodeError:
                        pass  # 如果解析失败则忽略

                # 获取AI配置
                cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'ai_config'))
                row = cursor.fetchone()
                if row and row[0]:
                    try:
                        ai_config = json.loads(row[0])
                        # 检查是否包含嵌套的ai_config对象
                        if isinstance(ai_config, dict) and 'ai_config' in ai_config:
                            # 提取嵌套的ai_config内容
                            nested_ai_config = ai_config.get('ai_config', {})
                            combined_config.update(nested_ai_config)
                        else:
                            # 直接合并AI配置
                            combined_config.update(ai_config)
                    except json.JSONDecodeError:
                        pass  # 如果解析失败则忽略

                conn.close()

            if combined_config:
                # 如果有用户配置,返回合并后的配置
                self.send_json({'success': True, 'data': combined_config, 'source': 'user'})
                return

            # 没有用户配置,返回系统配置
            config_path = os.path.join(BASE_DIR, 'config.json')
            if os.path.exists(config_path):
                with open(config_path, 'r', encoding='utf-8') as f:
                    config = json.load(f)
                # 提取学习相关配置
                learning_config = config.get('学习配置', config)
                self.send_json({'success': True, 'data': learning_config, 'source': 'system'})
            else:
                self.send_json({'success': True, 'data': self.get_default_learning_config(), 'source': 'default'})
        except Exception as e:
            self.send_json({'success': False, 'error': str(e)})
        finally:
            if conn:
                conn.close()

    def handle_config_post(self, user_id, data):
        """保存用户配置"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        conn = None
        try:
            conn = get_unified_db()
            cursor = conn.cursor()

            # 检查数据是否包含AI配置信息
            if 'provider' in data:
                # 这是一个AI配置,我们需要从现有的AI配置中合并新的数据
                cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'ai_config'))
                row = cursor.fetchone()

                if row and row[0]:
                    user_config = json.loads(row[0])
                else:
                    user_config = {}

                # 更新AI配置部分
                if 'ai_config' not in user_config:
                    user_config['ai_config'] = {}

                # 根据provider确定配置类型
                provider = data.get('provider', 'general')
                user_config['ai_config'][provider] = data

                config_json = json.dumps(user_config, ensure_ascii=False)

                if row:
                    # 更新AI配置
                    cursor.execute('UPDATE user_preferences SET value = ?, updated_at = CURRENT_TIMESTAMP WHERE user_id = ? AND key = ?', (config_json, user_id, 'ai_config'))
                else:
                    # 插入新AI配置
                    cursor.execute('INSERT INTO user_preferences (user_id, key, value) VALUES (?, ?, ?)', (user_id, 'ai_config', config_json))

                # 清理旧的包含AI配置的learning_config记录,避免冲突
                cursor.execute('DELETE FROM user_preferences WHERE user_id = ? AND key = ? AND value LIKE ?', (user_id, 'learning_config', '%"provider"%'))
            else:
                # 这是一般学习配置
                config_json = json.dumps(data, ensure_ascii=False)

                cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'learning_config'))
                row = cursor.fetchone()

                if row:
                    # 更新配置
                    cursor.execute('UPDATE user_preferences SET value = ?, updated_at = CURRENT_TIMESTAMP WHERE user_id = ? AND key = ?', (config_json, user_id, 'learning_config'))
                else:
                    # 插入新配置
                    cursor.execute('INSERT INTO user_preferences (user_id, key, value) VALUES (?, ?, ?)', (user_id, 'learning_config', config_json))

            conn.commit()
            # 返回成功响应,包括data字段以兼容前端期望
            self.send_json({'success': True, 'message': '配置已保存', 'data': data})
        except json.JSONDecodeError as e:
            self.send_json({'success': False, 'error': f'JSON解析错误: {str(e)}'})
        except Exception as e:
            self.send_json({'success': False, 'error': str(e)})
        finally:
            if conn:
                conn.close()

    # ============ AI 配置 API ============

    def handle_ai_config_get(self, path, user_id):
        """获取AI配置"""
        try:
            # 检查路径是哪个AI提供商的配置
            if '/api/ai-config/qianwen' in path:
                config_type = 'qianwen'
            elif '/api/ai-config/deepseek' in path:
                config_type = 'deepseek'
            elif '/api/ai-config/openai' in path:
                config_type = 'openai'
            else:
                config_type = 'general'

            # 如果用户已登录,尝试从用户配置获取
            if user_id:
                conn = get_unified_db()
                cursor = conn.cursor()

                cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'ai_config'))
                row = cursor.fetchone()

                if row and row[0]:
                    user_config = json.loads(row[0])
                    # 返回特定AI提供商的配置
                    ai_config = user_config.get('ai_config', {})
                    if config_type != 'general' and config_type in ai_config:
                        ai_config = ai_config[config_type]

                    conn.close()
                    self.send_json({'success': True, 'data': ai_config})
                    return
                conn.close()

            # 用户未登录或没有用户配置,返回系统级AI配置
            ai_config_path = os.path.join(BASE_DIR, 'ai_config.json')
            if os.path.exists(ai_config_path):
                with open(ai_config_path, 'r', encoding='utf-8') as f:
                    ai_config = json.load(f)
                if config_type != 'general' and config_type in ai_config:
                    ai_config = ai_config[config_type]
            else:
                # 返回默认配置
                ai_config = self.get_default_ai_config()
                if config_type != 'general':
                    ai_config = ai_config.get('providers', {}).get(config_type, {})

            self.send_json({'success': True, 'data': ai_config})
        except json.JSONDecodeError as e:
            self.send_json({'success': False, 'error': f'JSON解析错误: {str(e)}'})
        except Exception as e:
            self.send_json({'success': False, 'error': str(e)})

    def handle_ai_config_post(self, path, user_id, data):
        """保存AI配置"""
        if not user_id:
            self.send_json({'success': False, 'message': '未登录'}, 401)
            return

        # 验证必要的字段
        if not data.get('apiKey') or not data.get('provider'):
            self.send_json({'success': False, 'error': '缺少必要的API配置（apiKey和provider）'})
            return

        conn = None
        try:
            conn = get_unified_db()
            cursor = conn.cursor()

            # 获取当前用户配置
            cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'ai_config'))
            row = cursor.fetchone()

            if row and row[0]:
                user_config = json.loads(row[0])
            else:
                user_config = {}

            # 更新AI配置部分
            if 'ai_config' not in user_config:
                user_config['ai_config'] = {}

            # 根据路径确定是哪种AI配置
            if '/api/ai-config/qianwen' in path:
                user_config['ai_config']['qianwen'] = data
            elif '/api/ai-config/deepseek' in path:
                user_config['ai_config']['deepseek'] = data
            else:
                # 一般AI配置
                user_config['ai_config']['general'] = data

            config_json = json.dumps(user_config, ensure_ascii=False)

            if row:
                # 更新配置
                cursor.execute('UPDATE user_preferences SET value = ?, updated_at = CURRENT_TIMESTAMP WHERE user_id = ? AND key = ?', (config_json, user_id, 'ai_config'))
            else:
                # 插入新配置
                cursor.execute('INSERT INTO user_preferences (user_id, key, value) VALUES (?, ?, ?)', (user_id, 'ai_config', config_json))

            conn.commit()
            self.send_json({'success': True, 'message': 'AI配置已保存'})
        except Exception as e:
            self.send_json({'success': False, 'error': str(e)})
        finally:
            if conn:
                conn.close()

