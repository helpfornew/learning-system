            return

        conn = get_study_db()
        cursor = conn.cursor()

        try:
            # 检查记录是否存在且属于当前用户
            cursor.execute('SELECT id FROM study_time WHERE id = ? AND user_id = ?', (record_id, user_id))
            row = cursor.fetchone()

            if not row:
                self.send_json({'success': False, 'message': '学习时间记录不存在或无权限删除'}, 404)
                return

            # 删除记录
            cursor.execute('DELETE FROM study_time WHERE id = ? AND user_id = ?', (record_id, user_id))
            conn.commit()

