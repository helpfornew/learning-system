    # ============ 工具 API ============

    def handle_tools_time_tracker_get(self, user_id, params):
        """处理时间跟踪 GET 请求"""
        tracker = get_time_tracker()

        # 获取今日统计
        stats = tracker.get_today_stats()
        self.send_json({'success': True, 'data': stats, 'type': 'today_stats'})

    def handle_tools_time_tracker_post(self, user_id, data):
        """处理时间跟踪 POST 请求"""
        tracker = get_time_tracker()
        action = data.get('action', '')

        if action == 'start_session':
            subject = data.get('subject', '其他')
            task_type = data.get('task_type', '学习')
            result = tracker.start_session(subject, task_type)
            self.send_json({'success': True, 'data': result})

        elif action == 'end_session':
            session_id = data.get('session_id')
            efficiency_score = data.get('efficiency_score', 80)
            notes = data.get('notes', '')
            if session_id:
                result = tracker.end_session(session_id, efficiency_score, notes)
                self.send_json({'success': result.get('success', True), 'data': result})
            else:
                self.send_json({'success': False, 'error': '缺少 session_id'}, 400)

        elif action == 'get_weekly':
            result = tracker.get_weekly_report()
            self.send_json({'success': True, 'data': result})

        elif action == 'get_suggestions':
            result = tracker.get_suggestions()
            self.send_json({'success': True, 'data': result})

        elif action == 'get_config':
            result = tracker.get_config()
            self.send_json({'success': True, 'data': result})

        elif action == 'update_config':
            result = tracker.update_config(data.get('config', {}))
            self.send_json({'success': True, 'data': result})

        else:
            self.send_json({'success': False, 'error': '未知操作'}, 400)

    def handle_tools_reminder_get(self, user_id, params):
        """处理智能提醒 GET 请求"""
        reminder = get_reminder()

        # 获取时间表
        schedule = reminder.get_schedule()
        current_task = reminder.get_current_task()
        next_tasks = reminder.get_next_tasks(3)
        config = reminder.get_config()

        self.send_json({
            'success': True,
            'data': {
                'schedule': schedule,
                'current_task': current_task,
                'next_tasks': next_tasks,
                'config': config,
                'enabled': reminder.reminder_enabled
            }
        })

    def handle_tools_reminder_post(self, user_id, data):
        """处理智能提醒 POST 请求"""
        reminder = get_reminder()
        action = data.get('action', '')

        if action == 'send_test':
            title = data.get('title', '测试提醒')
            message = data.get('message', '这是一条测试消息')
            result = reminder.send_test_notification(title, message)
            self.send_json({'success': result.get('success', False), 'data': result})

        elif action == 'update_config':
            result = reminder.update_config(data.get('config', {}))
            self.send_json({'success': True, 'data': result})

        elif action == 'toggle':
            enabled = data.get('enabled', True)
            result = reminder.toggle_reminder(enabled)
            self.send_json({'success': True, 'data': result})

        else:
            self.send_json({'success': False, 'error': '未知操作'}, 400)

    def handle_tools_backup_get(self, user_id, params):
        """处理数据备份 GET 请求"""
        backup = get_backup_service()

        action = params.get('action', ['list'])[0]

        if action == 'list':
            backups = backup.list_backups()
            self.send_json({'success': True, 'data': backups})

        elif action == 'disk_space':
            result = backup.check_disk_space()
            self.send_json({'success': True, 'data': result})

        elif action == 'get_config':
            result = backup.get_config()
            self.send_json({'success': True, 'data': result})

        else:
            self.send_json({'success': False, 'error': '未知操作'}, 400)

    def handle_tools_backup_post(self, user_id, data):
        """处理数据备份 POST 请求"""
        backup = get_backup_service()
        action = data.get('action', '')

        if action == 'create':
            backup_type = data.get('type', 'full')
            result = backup.create_backup(backup_type)
            self.send_json({'success': result.get('success', False), 'data': result})

        elif action == 'delete':
            backup_path = data.get('path')
            if backup_path:
                result = backup.delete_backup(backup_path)
                self.send_json(result)
            else:
                self.send_json({'success': False, 'error': '缺少备份路径'}, 400)

        elif action == 'update_config':
            result = backup.update_config(data.get('config', {}))
            self.send_json({'success': True, 'data': result})

        else:
            self.send_json({'success': False, 'error': '未知操作'}, 400)

    # ============ 账号 API ============

    def handle_account_get(self, path):
        """处理账号 API GET 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # 验证用户（移除SSO机制,简化验证）
        if path == '/account/api/verify':
            # 当前移除了token验证,返回一个默认有效的用户（适用于单用户场景）
            # 在多用户场景中,这里可以改为基于session或其他认证方式
            self.send_json({'valid': True, 'user': {'id': 1, 'username': 'default_user', 'email': 'user@example.com', 'vip_level': 1}})
            return

        self.send_json({'error': 'Not Found'}, 404)

    def handle_account_post(self, path):
        """处理账号 API POST 请求"""
        parsed = urlparse(self.path)
        path = parsed.path

        # 获取请求体
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length).decode('utf-8') if content_length > 0 else '{}'

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            self.send_json({'success': False, 'message': '无效的请求'}, 400)
            return

        # 登录
        if path == '/account/api/login':
            username = data.get('username', '')
            password = data.get('password', '')

            # 输入验证
            if not username or len(username) < 3:
                self.send_json({'success': False, 'message': '用户名至少 3 个字符'}, 400)
                return

            if not password or len(password) < 6:
                self.send_json({'success': False, 'message': '密码至少 6 个字符'}, 400)
                return

            conn = get_unified_db()
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM users WHERE username = ?', (username,))
            row = cursor.fetchone()

            if row:
                # 验证密码哈希
                salt = row['salt']
                expected_hash = row['password_hash']
                actual_hash = hash_password(password, salt)

                if actual_hash == expected_hash:
                    # 检查账号状态
                    if row['status'] != 'active':
                        conn.close()
                        self.send_json({'success': False, 'message': '账号已被禁用'}, 403)
                        return

                    # 检查账号是否过期（兼容两种日期格式）
                    expires_at_str = row['expires_at']
                    try:
                        # 尝试完整格式
                        expires_at = datetime.datetime.strptime(expires_at_str, '%Y-%m-%d %H:%M:%S')
                    except ValueError:
                        try:
                            # 尝试仅日期格式
                            expires_at = datetime.datetime.strptime(expires_at_str, '%Y-%m-%d')
                        except ValueError:
                            # 如果都失败，设置为很远的未来日期
                            expires_at = datetime.datetime(2099, 12, 31)
                    
                    if datetime.datetime.now() > expires_at:
                        conn.close()
                        self.send_json({'success': False, 'message': '账号已过期'}, 403)
                        return

                    # 创建 session 并生成 token
                    token = create_session(row['id'])
                    
                    user_data = {
                        'user_id': row['id'],
                        'username': row['username'],
                        'email': row['email'],
                        'vip_level': row['vip_level'],
                        'created_at': row['created_at'],
                        'last_login': row['last_login'],
                        'token': token
                    }
                    conn.close()
                    self.send_json({'success': True, 'user': user_data, 'message': '登录成功'})
                    return

            conn.close()
            self.send_json({'success': False, 'message': '用户名或密码错误'}, 401)
            return

        # 注册
        if path == '/account/api/register':
            username = data.get('username', '')
            password = data.get('password', '')
            email = data.get('email', '')
            invite_code = data.get('invite_code', '')

            # 输入验证
            if not username or len(username) < 3:
                self.send_json({'success': False, 'message': '用户名至少 3 个字符'}, 400)
                return

            if not password or len(password) < 6:
                self.send_json({'success': False, 'message': '密码至少 6 个字符'}, 400)
                return

            # 验证邀请码（必须提供有效的邀请码）
            if not invite_code:
                self.send_json({'success': False, 'message': '请输入邀请码'}, 400)
                return

            # 验证邀请码是否有效
            conn = get_unified_db()
            cursor = conn.cursor()
            cursor.execute('''
                SELECT id, max_uses, current_uses
                FROM invite_codes
                WHERE code = ? AND is_active = 1 AND (max_uses = 0 OR current_uses < max_uses)
                AND expires_at > ?
            ''', (invite_code, datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')))
            invite_row = cursor.fetchone()

            if not invite_row:
                conn.close()
                self.send_json({'success': False, 'message': '邀请码无效或已过期'}, 400)
                return

            # 生成 salt 和密码哈希
            import secrets
            salt = secrets.token_hex(16)
            password_hash = hash_password(password, salt)

            # 创建用户（注册赠送 30 天 VIP）
            expires_at = datetime.datetime.now() + datetime.timedelta(days=30)

            cursor.execute('''
                INSERT INTO users (username, email, password_hash, salt, vip_level, expires_at, status)
                VALUES (?, ?, ?, ?, 1, ?, 'active')
            ''', (username, email if email else None, password_hash, salt,
                  expires_at.strftime('%Y-%m-%d %H:%M:%S')))

            user_id = cursor.lastrowid

            # 更新邀请码使用次数
            if invite_row['max_uses'] > 0:
                cursor.execute('''
                    UPDATE invite_codes SET current_uses = current_uses + 1 WHERE id = ?
                ''', (invite_row['id'],))

            # 创建 session 并生成 token
            token = create_session(user_id)

            user_data = {
                'user_id': user_id,
                'username': username,
                'email': email,
                'vip_level': 1,
                'expires_at': expires_at.strftime('%Y-%m-%d %H:%M:%S'),
                'token': token
            }
            self.send_json({'success': True, 'user': user_data, 'message': '注册成功'})
            conn.commit()
            conn.close()
            return

        # 退出登录
        if path == '/account/api/logout':
            auth_header = self.headers.get('Authorization', '')
            token = None
            
            if auth_header:
                parts = auth_header.split()
                if len(parts) == 2 and parts[0].lower() == 'bearer':
                    token = parts[1]

            if token:
                invalidate_session(token)
                self.send_json({'success': True, 'message': '退出登录成功'})
            else:
                self.send_json({'success': False, 'message': '未提供有效的 token'})
            return

        # 创建邀请码（仅管理员,vip_level >= 999）
        if path == '/account/api/invite-code':
            auth_header = self.headers.get('Authorization', '')
            token = None
            
            if auth_header:
                parts = auth_header.split()
                if len(parts) == 2 and parts[0].lower() == 'bearer':
                    token = parts[1]

            if not token:
                self.send_json({'success': False, 'message': '未提供有效的 token'})
                return

            # 验证 token 并检查是否为管理员
            result = verify_token(token)
            if not result['valid']:
                self.send_json({'success': False, 'message': 'token 无效或已过期'})
                return

            conn = get_unified_db()
            cursor = conn.cursor()
            cursor.execute('SELECT vip_level FROM users WHERE id = ?', (result['user_id'],))
            user_row = cursor.fetchone()
            
            if not user_row or user_row['vip_level'] < 999:
                conn.close()
                self.send_json({'success': False, 'message': '权限不足：仅管理员可创建邀请码'})
                return

            # 获取请求数据
            invite_data = data.get('invite_code', data)  # 兼容两种格式
            code = invite_data.get('code', '')
            max_uses = invite_data.get('max_uses', 0)
            days = invite_data.get('days', 365)
            remark = invite_data.get('remark', '')

            # 如果没有指定 code,自动生成
            if not code:
                import random
                code = 'INV' + ''.join([str(random.randint(0, 9)) for _ in range(8)])

            expires_at = datetime.datetime.now() + datetime.timedelta(days=days)

            try:
                cursor.execute('''
                    INSERT INTO invite_codes (code, max_uses, current_uses, expires_at, remark)
                    VALUES (?, ?, 0, ?, ?)
                ''', (code, max_uses if max_uses > 0 else 0, 
                      expires_at.strftime('%Y-%m-%d %H:%M:%S'), remark))
                conn.commit()
                invite_id = cursor.lastrowid
                self.send_json({
                    'success': True,
                    'data': {
                        'id': invite_id,
                        'code': code,
                        'max_uses': max_uses,
                        'expires_at': expires_at.strftime('%Y-%m-%d %H:%M:%S'),
                        'remark': remark
                    },
                    'message': '邀请码创建成功'
                })
            except sqlite3.IntegrityError:
                self.send_json({'success': False, 'message': '邀请码已存在'})
            finally:
                conn.close()
            return

        self.send_json({'error': 'Not Found'}, 404)

    def log_message(self, format, *args):
        """自定义日志格式"""
        print(f"[{datetime.datetime.now().strftime('%H:%M:%S')}] {args[0]}")


    def handle_ai_analysis_proxy(self, user_id, data):
        """AI分析API代理 - 用于避免前端CORS问题"""
        try:
            # 添加调试信息
            print(f"[YoudaoAPI] AI分析代理收到请求: {list(data.keys())}")

            # 从前端请求中获取API密钥（如果有的话）作为覆盖选项
            request_api_key = data.get('apiKey')

            # 尝试从数据库获取存储的AI配置
            conn = get_unified_db()
            cursor = conn.cursor()
            cursor.execute('SELECT value FROM user_preferences WHERE user_id = ? AND key = ?', (user_id, 'ai_config'))
            row = cursor.fetchone()

            if not row or not row[0]:
                conn.close()
                print("[ERROR] 未配置AI API密钥")
                self.send_json({'success': False, 'error': '未配置AI API密钥'})
                return

            ai_config = json.loads(row[0])
            qwen_config = ai_config.get('ai_config', {}).get('qwen', {})
            conn.close()

            # 如果前端提供了API密钥,使用前端的；否则使用数据库中的
            api_key = request_api_key if request_api_key else qwen_config.get('apiKey', '')

            if not api_key:
                print("[ERROR] 未配置API密钥")
                self.send_json({'success': False, 'error': '未配置API密钥'})
                return

            # 优先使用数据库中的配置,然后才是前端传入的,最后才是默认值
            api_endpoint = qwen_config.get('apiEndpoint', data.get('apiEndpoint', 'https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions'))
            # 优先使用数据库中的模型配置,如果数据库没有再用前端传递的,最后用默认值
            model = qwen_config.get('model', data.get('model', 'qwen-max'))
            messages = data.get('messages', [])
            max_tokens = data.get('maxTokens', qwen_config.get('maxTokens', 2000))
            temperature = data.get('temperature', qwen_config.get('temperature', 0.7))

            print(f"[YoudaoAPI] 使用API端点: {api_endpoint}")
            print(f"[YoudaoAPI] 使用模型: {model}")
            print(f"[YoudaoAPI] 消息数量: {len(messages) if isinstance(messages, list) else 'N/A'}")

            # 检查是否有图像内容（多模态请求）
            has_image_content = False
            for msg in messages:
                if isinstance(msg, dict) and 'content' in msg:
                    if isinstance(msg['content'], list):
                        # 检查多模态内容
                        for item in msg['content']:
                            if isinstance(item, dict) and item.get('type') == 'image_url':
                                has_image_content = True
                                break
                if has_image_content:
                    break

            # 如果检测到图像内容,强制使用兼容模式API端点,因为老式端点不支持图像
            if has_image_content and 'dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation' in api_endpoint:
                print("[WARNING] 检测到图像内容,切换到兼容模式API端点")
                api_endpoint = 'https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions'
                print(f"[YoudaoAPI] 切换后的API端点: {api_endpoint}")

            # 根据API端点类型构建适当的请求
            headers = {
                'Authorization': f'Bearer {api_key}',
                'Content-Type': 'application/json'
            }

            # 根据API端点类型构建适当的请求格式
            if 'dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation' in api_endpoint:
                # 老式的通义千问API格式,需要使用input.prompt
                if messages and isinstance(messages, list) and len(messages) > 0:
                    # 提取用户的消息内容
                    user_message = ""
                    for msg in messages:
                        if isinstance(msg, dict):
                            if msg.get('role') == 'user':
                                content = msg.get('content', '')
                                if isinstance(content, str):
                                    user_message = content
                                elif isinstance(content, list):
                                    # 处理多模态内容 - 提取文本部分
                                    text_parts = []
                                    image_count = 0
                                    for item in content:
                                        if isinstance(item, dict):
                                            if item.get('type') == 'text':
                                                text_parts.append(item.get('text', ''))
                                            elif item.get('type') == 'image_url':
                                                image_count += 1
                                                # 对于老式API,需要跳过图像
                                                print(f"[YoudaoAPI] 跳过图像内容 (数量: {image_count})")
                                    user_message = " ".join(text_parts)
                                break

                    payload = {
                        "model": model,
                        "input": {
                            "prompt": user_message
                        },
                        "parameters": {
                            "max_tokens": max_tokens,
                            "temperature": temperature
                        }
                    }
                else:
                    print("[ERROR] 消息内容为空")
                    self.send_json({'success': False, 'error': '消息内容不能为空'})
                    return

            elif 'dashscope.aliyuncs.com/compatible-mode/v1/chat/completions' in api_endpoint:
                # 新的兼容OpenAI格式的API - 支持多模态
                processed_messages = []
                for msg in messages:
                    if isinstance(msg, dict) and 'content' in msg and isinstance(msg['content'], list):
                        # 处理多模态消息
                        print(f"[YoudaoAPI] 处理多模态消息,内容类型: {[item.get('type') if isinstance(item, dict) else type(item) for item in msg['content']]}")
                        new_content = []
                        for item in msg['content']:
                            if isinstance(item, dict) and item.get('type') == 'image_url':
                                # 检查图像URL
                                img_url = item['image_url']['url']

                                # 对于通义千问,检查是否为有效的base64图像
                                if img_url.startswith('data:image'):
                                    # 验证图像是否足够大
                                    base64_part = img_url.split(',', 1)[1] if ',' in img_url else ''

                                    # 如果是占位符或极小图像,添加警告
                                    if len(base64_part) < 100:  # 这可能表示一个极小的图像
                                        print(f"[WARNING] 检测到小图像,长度: {len(base64_part)}")

                                    new_content.append(item)
                                else:
                                    new_content.append(item)
                            else:
                                # 文本内容直接添加
                                new_content.append(item)

                        processed_msg = msg.copy()
                        processed_msg['content'] = new_content
                        processed_messages.append(processed_msg)
                    else:
                        # 普通消息直接添加
                        processed_messages.append(msg)

                payload = {
                    'model': model,
                    'messages': processed_messages,
                    'max_tokens': max_tokens,
                    'temperature': temperature
                }
            elif 'deepseek.com' in api_endpoint:
                # DeepSeek API格式
                payload = {
                    'model': model,
                    'messages': messages,
                    'max_tokens': max_tokens,
                    'temperature': temperature
                }
            else:
                # 默认使用OpenAI兼容格式
                payload = {
                    'model': model,
                    'messages': messages,
                    'max_tokens': max_tokens,
                    'temperature': temperature
                }

            print(f"[YoudaoAPI] 发送请求到: {api_endpoint}")
            print(f"[YoudaoAPI] 请求头: {dict((k, v if k != 'Authorization' else '***MASKED***') for k, v in headers.items())}")
            print(f"[YoudaoAPI] 请求体摘要: model={model}, msg_count={len(payload.get('messages', [])) if 'messages' in payload else 'N/A'}")

            # 发送请求到外部AI API
            response = requests.post(
                api_endpoint,
                headers=headers,
                json=payload,
                timeout=300  # 增加超时时间至120秒,以处理较大的图像或复杂分析请求
            )

            print(f"[YoudaoAPI] API响应状态码: {response.status_code}")

            # 记录API响应的具体内容
            try:
                response_text = response.text
                print(f"[YoudaoAPI] API原始响应: {response_text[:500]}...")  # 只打印前500字符

                if response.status_code in [200, 201]:
                    response_data = response.json()
                    print(f"[YoudaoAPI] API JSON解析响应: {json.dumps(response_data, ensure_ascii=False)[:1000]}...")  # 只打印前1000字符
                else:
                    print(f"[YoudaoAPI] 非成功响应: {response_text}")
            except Exception as e:
                print(f"[YoudaoAPI] 响应解析错误: {e}")

            # 返回API响应
            if response.status_code in [200, 201]:
                try:
                    response_data = response.json()
                    print(f"[YoudaoAPI] API响应成功")

                    # 确保响应数据符合标准格式
                    if 'dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation' in api_endpoint:
                        # 老式API响应格式可能不同,需要适配
                        if 'output' in response_data and 'choices' in response_data['output']:
                            # 适配为标准格式
                            adapted_response = {
                                'choices': [
                                    {
                                        'message': {
                                            'content': choice.get('text', '') if isinstance(choice, dict) else str(choice)
                                        }
                                    }
                                    for choice in response_data['output']['choices']
                                ],
                                'usage': response_data.get('usage', {}),
                                'model': response_data.get('model', model),
                                'created': response_data.get('created', int(time.time()))
                            }
                            print(f"[YoudaoAPI] 老式API响应已适配,返回: {json.dumps(adapted_response, ensure_ascii=False)[:500]}...")
                            self.send_json({'success': True, 'data': adapted_response})
                        else:
                            # 如果响应格式不符合预期,直接返回
                            print(f"[YoudaoAPI] 老式API响应直接返回")
                            self.send_json({'success': True, 'data': response_data})
                    else:
                        # 确保兼容模式API的响应格式标准化
                        standard_response = {
                            'choices': response_data.get('choices', []),
                            'usage': response_data.get('usage', {}),
                            'model': response_data.get('model', model),
                            'created': response_data.get('created', int(time.time())),
                            'id': response_data.get('id', '')
                        }
                        print(f"[YoudaoAPI] 标准化兼容模式API响应")
                        self.send_json({'success': True, 'data': standard_response})
                except json.JSONDecodeError:
                    print(f"[YoudaoAPI] 响应不是JSON格式: {response.text[:200]}")
                    # 如果响应不是JSON格式,返回原始文本
                    self.send_json({'success': True, 'data': {'choices': [{'message': {'content': response.text}}]}})
            else:
                # 从响应体获取更详细的错误信息
                try:
                    error_details = response.text
                    print(f"[ERROR] API请求失败: {response.status_code}, 详情: {error_details[:500]}")

                    # 检查是否是图像大小错误
                    if 'image length and width' in error_details and 'larger than 10' in error_details:
                        print("[ERROR] 图像尺寸错误: 图像宽高必须大于10像素")
                        self.send_json({
                            'success': False,
                            'error': '图像尺寸过小,宽高必须大于10像素',
                            'details': error_details
                        })
                    # 检查URL错误（不支持图像的API端点）
                    elif 'url error' in error_details:
                        print("[ERROR] 图像URL错误: 请确保使用支持图像的API端点")
                        self.send_json({
                            'success': False,
                            'error': '图像URL错误: 当前API端点不支持图像',
                            'details': error_details
                        })
                    else:
                        self.send_json({'success': False, 'error': f'API请求失败: {response.status_code}', 'details': error_details})
                except Exception as e:
                    error_details = str(response.reason)
                    print(f"[ERROR] 处理响应失败: {e}")
                    self.send_json({'success': False, 'error': f'API请求失败: {response.status_code}', 'details': error_details})

        except requests.exceptions.RequestException as e:
            print(f"[ERROR] 网络请求错误: {str(e)}")
            self.send_json({'success': False, 'error': f'网络请求错误: {str(e)}'})
        except Exception as e:
            print(f"[ERROR] 其他错误: {str(e)}")
            self.send_json({'success': False, 'error': str(e)})


def main():
    """启动统一服务器"""
    # 初始化数据库
    init_mistake_db()
    init_study_db()
    init_vocabulary_db()

    # 确保统一数据库存在并创建所需表
    print("检查统一数据库结构...")
    conn = get_unified_db()
    cursor = conn.cursor()

    # 启用 WAL 模式
    cursor.execute('PRAGMA journal_mode=WAL')

    # 创建 users 表（如果不存在）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            email TEXT UNIQUE,
            password_hash TEXT NOT NULL,
            salt TEXT NOT NULL,
            status TEXT DEFAULT 'active',
            vip_level INTEGER DEFAULT 0,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            last_login DATETIME,
            expires_at DATETIME,
            device_limit INTEGER DEFAULT 3,
            login_count INTEGER DEFAULT 0
        )
    ''')

    # 创建 mistakes 表（如果不存在）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS mistakes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            subject_id INTEGER NOT NULL,
            content TEXT,
            wrong_answer TEXT,
            correct_answer TEXT,
            error_reason TEXT,
            difficulty INTEGER DEFAULT 2,
            images_path TEXT,
            knowledge_points TEXT,
            tags TEXT,
            analysis TEXT,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            is_deleted BOOLEAN DEFAULT 0,
            review_count INTEGER DEFAULT 0,
            last_review_date TEXT,
            next_review_date TEXT,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # 创建 study_time 表（如果不存在）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS study_time (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            subject TEXT NOT NULL,
            duration REAL NOT NULL,
            date TEXT NOT NULL,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # 创建 course_schedule 表（如果不存在）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS course_schedule (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            subject TEXT NOT NULL,
            weekday INTEGER NOT NULL,
            start_time TEXT NOT NULL,
            end_time TEXT NOT NULL,
            is_active BOOLEAN DEFAULT 1,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # 创建 user_preferences 表（如果不存在）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS user_preferences (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            key TEXT NOT NULL,
            value TEXT,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users (id),
            UNIQUE(user_id, key)
        )
    ''')

    # 创建 sessions 表（用于 token 认证）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            token TEXT UNIQUE NOT NULL,
            expires_at DATETIME NOT NULL,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (user_id) REFERENCES users (id)
        )
    ''')

    # 创建 invite_codes 表（邀请码表）
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS invite_codes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            code TEXT UNIQUE NOT NULL,
            max_uses INTEGER DEFAULT 0,
            current_uses INTEGER DEFAULT 0,
            expires_at DATETIME NOT NULL,
            is_active BOOLEAN DEFAULT 1,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            remark TEXT
        )
    ''')

    # 检查是否需要创建默认邀请码
    cursor.execute('SELECT id FROM invite_codes WHERE code = ?', ('ADMIN2026',))
    if not cursor.fetchone():
        # 创建一个默认邀请码（无限次使用,1 年有效期）
        default_expires = datetime.datetime.now() + datetime.timedelta(days=365)
        cursor.execute('''
            INSERT INTO invite_codes (code, max_uses, current_uses, expires_at, remark)
            VALUES (?, 0, 0, ?, '默认邀请码,无限次使用')
        ''', ('ADMIN2026', default_expires.strftime('%Y-%m-%d %H:%M:%S')))
        print("已创建默认邀请码：ADMIN2026")

    conn.commit()

    # 创建默认管理员账号（如果不存在）
    import secrets
    salt = secrets.token_hex(16)
    password_hash = hash_password('admin123', salt)

    cursor.execute('''
        INSERT OR IGNORE INTO users (username, email, password_hash, salt, status, vip_level, expires_at)
        VALUES (?, ?, ?, ?, 'active', 999, '2099-12-31 23:59:59')
    ''', ('admin', 'admin@mistake.com', password_hash, salt))

    conn.commit()
    conn.close()
    print("统一数据库初始化完成")
    print("表结构：users, mistakes, study_time, course_schedule, user_preferences, sessions, invite_codes")
    print("表结构：users, mistakes, study_time, course_schedule, user_preferences")

    server = HTTPServer((HOST, PORT), UnifiedHandler)
    print(f"╔════════════════════════════════════════════════════╗")
    print(f"║     高考学习系统 - 统一服务器已启动                 ║")
    print(f"╠════════════════════════════════════════════════════╣")
    print(f"║  访问地址：http://localhost:{PORT}                    ║")
    if DEV_MODE:
        print(f"║  模式：开发模式 (代理到 Vite: {VITE_DEV_SERVER})    ║")
        print(f"║  提示：修改代码后刷新浏览器即可生效                ║")
    else:
        print(f"║  模式：生产模式 (静态文件)                        ║")
        print(f"║  提示：运行前需要 npm run build 构建前端           ║")
    print(f"║                                                    ║")
    print(f"║  路由说明：                                         ║")
    print(f"║    /           - 学习系统主页                      ║")
    print(f"║    /tools      - 工具中心（时间跟踪/提醒/备份）    ║")
    print(f"║    /mistake/   - 错题系统前端                      ║")
    print(f"║    /api/*      - 统一 API（错题 + 学习时间 + 配置）   ║")
    print(f"║    /api/tools  - 工具 API（时间跟踪/提醒/备份）     ║")
    print(f"║    /account/*  - 账号 API（登录/注册）               ║")
    print(f"║                                                    ║")
    print(f"║  数据库：统一数据库 (unified_learning.db)           ║")
    print(f"║  表格：users, mistakes, study_time, course_schedule, ║")
    print(f"║       user_preferences                             ║")
    print(f"╚════════════════════════════════════════════════════╝")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n服务器已停止")
        server.shutdown()


if __name__ == '__main__':
    main()
