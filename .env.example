# 高考学习系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ============ 系统配置 ============
# 系统安装目录 (默认：/opt/learning-system)
LEARNING_SYSTEM_DIR=/opt/learning-system

# 数据存储目录 (默认：/var/lib/learning-system)
LEARNING_SYSTEM_DATA=/var/lib/learning-system

# ============ 网络配置 ============
# 监听地址 (默认：0.0.0.0)
LEARNING_SYSTEM_HOST=0.0.0.0

# 监听端口 (默认：8080)
LEARNING_SYSTEM_PORT=8080

# ============ 数据库配置 ============
# 数据库路径 (默认：${LEARNING_SYSTEM_DATA}/database)
LEARNING_SYSTEM_DB_PATH=

# ============ AI API 密钥 ============
# 通义千问 API Key
QIANWEN_API_KEY=your_qianwen_api_key_here

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============ 安全配置 ============
# 允许的跨域 Origin (多个用逗号分隔)
ALLOWED_ORIGIN=*

# 会话密钥 (用于加密 session，32 位随机字符串)
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(16))"
SESSION_SECRET=

# ============ 日志配置 ============
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径 (默认：/var/log/learning-system/server.log)
LOG_FILE_PATH=

# ============ 备份配置 ============
# 备份保留天数
BACKUP_KEEP_DAYS=30

# 是否启用压缩备份
BACKUP_COMPRESS=true
