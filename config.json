    },
    "周三": {
      "类型": "分析日",
      "重点科目": ["全部"],
      "任务": "AI分析错题，生成薄弱知识点清单"
    },
    "周四": {
      "类型": "突破日",
      "重点科目": ["英语"],
      "任务": "针对英语薄弱点专项训练"
    },
    "周五": {
      "类型": "突破日",
      "重点科目": ["化学"],
      "任务": "针对化学薄弱点专项训练"
    },
    "周六": {
      "类型": "突破日",
      "重点科目": ["语文", "政治"],
      "任务": "语文作文+政治背诵"
    },
    "周日": {
      "类型": "复盘日",
      "重点科目": ["全部"],
      "任务": "小测验检验效果，规划下周"
    }
  },
