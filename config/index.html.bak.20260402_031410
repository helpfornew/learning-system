                mathOrPhysics = '数学';
            } else if (dayIndex === 2 || dayIndex === 4 || dayIndex === 6) {
                dayType = '双日 (物理)';
                mathOrPhysics = '物理';
            } else {
                dayType = '周日·周测';
                mathOrPhysics = '周测';
            }

            // 单双周判断
            const weekType = (weekOfTerm % 2 === 1) ? '单周·政治' : '双周·语文';

            // 周测科目表 (6 周计划)
            const testSubjects = [
                { sub1: '英语', sub2: '化学' },
                { sub1: '数学', sub2: '物理' },
                { sub1: '语文', sub2: '英语' },
                { sub1: '化学', sub2: '政治' },
                { sub1: '数学', sub2: '政治' },
                { sub1: '全科模拟', sub2: '全科模拟' }
            ];
            const weekIdx = (weekOfTerm - 1) % 6;

            return {
                dayIndex,
                dayType,
                mathOrPhysics,
                weekOfTerm,
                weekType,
                testSub1: testSubjects[weekIdx].sub1,
                testSub2: testSubjects[weekIdx].sub2
