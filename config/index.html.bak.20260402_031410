        function getDateInfo() {
            const now = new Date();
            const dayIndex = now.getDay(); // 0=周日，1=周一...6=周六

            // 计算第几周 (从 3 月 1 日算起)
            const startOfTerm = new Date(2025, 2, 1); // 3 月 1 日
            const diffDays = Math.floor((now - startOfTerm) / (1000*60*60*24));
            let weekOfTerm = Math.floor(diffDays / 7) + 1;
            if (weekOfTerm < 1) weekOfTerm = 1;
            if (weekOfTerm > 6) weekOfTerm = ((weekOfTerm-1) % 6) + 1;

            // 单双日判断
            let dayType = '周测日';
            let mathOrPhysics = '周测';
            if (dayIndex === 1 || dayIndex === 3 || dayIndex === 5) {
