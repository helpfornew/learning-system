                    if (returnUrl) {
                        setTimeout(() => window.location.href = decodeURIComponent(returnUrl), 1000);
                    } else {
                        setTimeout(() => showMainPage(), 1000);
                    }
                } else {
                    showMessage(result.message || '登录失败', 'error');
                }
            } catch (error) {
                console.error('登录失败:', error);
                showMessage('网络连接失败，请检查服务器', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = '登录';
            }
        }

