        // 获取自定义时间表
        let cachedCustomSchedule = null;
        function getCustomScheduleForDay(dayIndex) {
            if (cachedCustomSchedule === null) {
                // 同步获取（仅在初始化时调用一次）
                try {
                    const xhr = new XMLHttpRequest();
                    xhr.open('GET', `${API_BASE}/api/schedule/custom`, false);
                    xhr.send();
                    if (xhr.status === 200) {
                        const data = JSON.parse(xhr.responseText);
                        if (data.enabled && data.schedules) {
                            const dayKey = dayIndex === 0 ? '0' : String(dayIndex);
                            const customData = data.schedules[dayKey];
                            if (customData && Array.isArray(customData)) {
                                cachedCustomSchedule = customData.map(slot => ({
                                    start: timeToDecimal(slot.start),
                                    end: timeToDecimal(slot.end),
                                    title: slot.title,
                                    desc: slot.desc || '',
                                    subject: slot.subject || slot.tag || '学习',
                                    tag: slot.tag || '学习'
                                }));
                            }
                        }
                    }
                } catch (e) {
                    console.log('[getCustomSchedule] 获取失败:', e.message);
                }
            }
            return cachedCustomSchedule;
        }

        // 时间格式转换 (HH:MM -> 小数)
        function timeToDecimal(timeStr) {
            const [hours, minutes] = timeStr.split(':').map(Number);
            return hours + minutes / 60;
        }

        // 格式化时间 (小数转 HH:MM)
        function formatTime(decimal) {
            const hours = Math.floor(decimal);
            const minutes = Math.round((decimal - hours) * 60);
            return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
        }

        // 渲染详细时间表
        function renderDetailedSchedule() {
            const schedule = buildDetailedSchedule();
            const info = getDateInfo();
            const now = new Date();
            const currentDec = now.getHours() + now.getMinutes() / 60;

            // 更新徽章
            document.getElementById('dayTypeBadge').textContent = `${info.dayType} · 第${info.weekOfTerm}周`;
            document.getElementById('weekTypeBadge').textContent = info.weekType;

            // 找到当前和下一个任务
            let currentTask = null;
            let nextTask = null;

            for (let i = 0; i < schedule.length; i++) {
                const item = schedule[i];
                if (currentDec >= item.start && currentDec < item.end) {
                    currentTask = item;
                    nextTask = schedule[i + 1] || null;
                    break;
                }
                // 如果还没找到当前任务，且这个任务在未来，那就是下一个任务
                if (!currentTask && currentDec < item.start) {
                    nextTask = item;
                }
            }

            // 更新当前任务卡片
            const currentTaskNameEl = document.querySelector('#currentTask .current-task-name');
            const currentTaskTimeEl = document.querySelector('#currentTask .current-task-time');
            const currentTaskEl = document.getElementById('currentTask');
            const nextTaskNameEl = document.getElementById('nextTask');
            const nextTimeEl = document.getElementById('nextTime');

            if (currentTask) {
                currentTaskNameEl.textContent = currentTask.title;
                currentTaskTimeEl.textContent = `${formatTime(currentTask.start)} - ${formatTime(currentTask.end)}`;
                currentTaskEl.style.background = 'linear-gradient(135deg, #667eea, #764ba2)';
            } else {
                // 当前时间不在任何时间段内
                currentTaskNameEl.textContent = '休息时间';
                currentTaskTimeEl.textContent = '暂无任务';
                currentTaskEl.style.background = 'linear-gradient(135deg, #999, #666)';
            }

            if (nextTask) {
                nextTaskNameEl.textContent = nextTask.title;
                nextTimeEl.textContent = formatTime(nextTask.start);
            } else {
                nextTaskNameEl.textContent = '今日学习结束';
                nextTimeEl.textContent = '明天继续';
            }

            // 渲染时间表
            const container = document.getElementById('scheduleList');
            let html = '<div class="flow-grid">';

            schedule.forEach((item) => {
                const completed = (currentDec >= item.end);
                const isCurrent = (currentDec >= item.start && currentDec < item.end);

                let rowClass = 'flow-row';
                if (isCurrent) rowClass += ' current';
                else if (completed) rowClass += ' completed';

                let tagClass = 'flow-tag';
                if (item.tag === 'exercise') tagClass += ' exercise';
                else if (item.tag === '休息' || item.tag === 'rest') tagClass += ' rest';
                else if (item.tag === 'daily') tagClass += ' daily';

                html += `
                    <div class="${rowClass}">
                        <span class="flow-time">${formatTime(item.start)}</span>
                        <div>
                            <div class="flow-task">${item.title}</div>
                            <div class="flow-task-desc">${item.desc}</div>
                        </div>
                        <span class="${tagClass}">${item.subject}</span>
                    </div>
                `;
            });

            html += '</div>';
            container.innerHTML = html;
        }

        // 更新当前任务
        function updateCurrentTask(schedule) {
            const now = new Date();
            const currentDecimal = now.getHours() + now.getMinutes() / 60;

            let current = null;
            let next = null;

            for (let i = 0; i < schedule.length; i++) {
                const [start, end] = schedule[i].time.split('-');
                const [startH, startM] = start.split(':').map(Number);
                const [endH, endM] = end.split(':').map(Number);
                const startDec = startH + startM / 60;
                const endDec = endH + endM / 60;

                if (currentDecimal >= startDec && currentDecimal < endDec) {
                    current = schedule[i];
                    next = schedule[i + 1] || null;
                    break;
                }
            }

            // 如果当前时间不在任何时间段内，找到下一个即将到来的任务
            if (!current) {
                for (let i = 0; i < schedule.length; i++) {
                    const [start, end] = schedule[i].time.split('-');
                    const [startH, startM] = start.split(':').map(Number);
                    const startDec = startH + startM / 60;

                    if (currentDecimal < startDec) {
                        next = schedule[i];
                        break;
                    }
                }
            }

            // 更新显示
            const currentTaskEl = document.querySelector('#currentTask .current-task-name');
            const currentTimeEl = document.querySelector('#currentTask .current-task-time');
            const nextTaskEl = document.getElementById('nextTask');
            const nextTimeEl = document.getElementById('nextTime');

            if (current) {
                currentTaskEl.textContent = current.subject;
                currentTimeEl.textContent = current.time;
                currentTaskEl.parentElement.parentElement.style.background = 'linear-gradient(135deg, #667eea, #764ba2)';
            } else {
                currentTaskEl.textContent = '休息时间';
                currentTimeEl.textContent = '暂无任务';
                currentTaskEl.parentElement.parentElement.style.background = 'linear-gradient(135deg, #999, #666)';
            }

            if (next) {
                nextTaskEl.textContent = next.subject;
                nextTimeEl.textContent = next.time;
            } else {
                nextTaskEl.textContent = '今日学习结束';
                nextTimeEl.textContent = '明天继续';
            }
        }

        // 快速操作
        function openMistakeSystem() {
            // 检测是否在Electron环境中
            const isElectron = typeof window !== 'undefined' && window.process && window.process.type;

            // 直接访问错题系统，不再传递token（移除SSO机制）
            let url = MISTAKE_SYSTEM_URL;

            // 确保URL是有效的HTTP URL
            if (!url.startsWith('http')) {
                const baseUrl = window.location.origin;
                url = baseUrl + '/mistake/';
            }

            if (isElectron && window.electronAPI) {
                // 在Electron环境中，使用electronAPI打开外部链接
                window.electronAPI.openExternal(url);
            } else {
                // 在浏览器环境中，在新标签页中打开
                window.open(url, '_blank');
            }
        }

        function startTimeTracker() {
            // 跳转到工具中心页面（包含时间跟踪功能）
            window.open('/tools', '_blank');
        }

        function startFocusMode() {
            // 打开专注模式页面
            alert('专注模式使用说明：\n\n请在终端运行：\nbash ~/learning_system/tools/focus_mode.sh\n\n或者直接运行 Electron 应用，在工具菜单中选择专注模式');
        }

        // 打开单词卡片系统
        function openWordcardSystem() {
            // 直接访问单词卡片系统
            let url = '/wordcard/';

            // 确保URL是有效的HTTP URL
            if (!url.startsWith('http')) {
                const baseUrl = window.location.origin;
                url = baseUrl + '/wordcard/';
            }

            // 在新标签页中打开
            window.open(url, '_blank');
        }

        // DOM 加载完成后执行
        document.addEventListener('DOMContentLoaded', function() {
            console.log('[DOMContentLoaded] 页面加载完成，开始初始化...');
            // 检查登录状态
            checkLoginStatus();
            // 每 30 秒刷新
            setInterval(loadData, 30000);
        });

        // 快捷键监听：Shift+C 打开错题系统
        document.addEventListener('keydown', function(event) {
            if (event.shiftKey && (event.key === 'C' || event.key === 'c' || event.keyCode === 67)) {
                // 阻止默认行为
                event.preventDefault();
                // 检查是否已登录
                if (currentUser) {
                    openMistakeSystem();
                } else {
                    alert('请先登录');
                }
            }
        });
    </script>
</body>
</html>






