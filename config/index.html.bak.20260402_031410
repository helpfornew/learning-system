<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>高考学习系统 · 统一主页</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        /* 登录页面样式 */
        #loginPage {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }
        #loginPage.active {
            display: flex;
        }
        .login-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .login-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #333;
            text-align: center;
            margin-bottom: 30px;
        }
        .login-tabs {
            display: flex;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
        }
        .login-tab {
            flex: 1;
            padding: 12px;
            text-align: center;
            cursor: pointer;
            font-weight: 500;
            color: #666;
            transition: all 0.3s;
        }
        .login-tab.active {
            color: #667eea;
            border-bottom: 2px solid #667eea;
        }
        .login-form input {
            width: 100%;
            padding: 14px;
            margin-bottom: 16px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .login-form input:focus {
            border-color: #667eea;
            outline: none;
        }
        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .login-btn:hover {
            transform: translateY(-2px);
        }
        .login-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
        .login-message {
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 16px;
            font-size: 14px;
            display: none;
        }
        .login-message.error {
            background: #fee;
            color: #c00;
            display: block;
        }
        .login-message.success {
            background: #efe;
            color: #060;
            display: block;
        }
        .login-tip {
            text-align: center;
            color: #999;
            font-size: 13px;
            margin-top: 16px;
        }
        .user-info-card {
            display: none;
            background: white;
            border-radius: 20px;
            padding: 30px;
            text-align: center;
        }
        .user-avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 32px;
            color: white;
        }
        .user-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }
        .user-email {
            color: #666;
            margin-bottom: 20px;
        }
        .user-vip {
            display: inline-block;
            background: linear-gradient(135deg, #ffd700, #ffed4e);
            color: #333;
            padding: 6px 16px;
            border-radius: 20px;
            font-weight: 600;
            margin-bottom: 20px;
        }
        .logout-btn {
            padding: 12px 30px;
            background: #ff4d4f;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* 头部 */
        .header {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }
        .header-info {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 15px;
        }
        .header-badge {
            background: #f0f3ff;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 0.9rem;
            color: #667eea;
        }

        /* 网格布局 */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        /* 卡片样式 */
        .card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f3ff;
        }
        .card-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #333;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card-body {
            min-height: 200px;
        }

        /* 实时任务 */
        .current-task {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 25px;
            border-radius: 15px;
            margin-bottom: 15px;
        }
        .current-task-label {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 10px;
        }
        .current-task-name {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        .current-task-time {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        /* 统计卡片 */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }
        .stat-item {
            text-align: center;
            padding: 20px;
            background: #f8f9ff;
            border-radius: 12px;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: #667eea;
        }
        .stat-label {
            font-size: 0.85rem;
            color: #666;
            margin-top: 5px;
        }

        /* 按钮 */
        .btn {
            display: inline-block;
            padding: 12px 24px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            border: none;
            font-size: 0.95rem;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }
        .btn-success {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: white;
        }
        .btn-warning {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            color: white;
        }
        .btn-block {
            display: block;
            width: 100%;
            text-align: center;
            margin-bottom: 10px;
        }

        /* 课表 */
        .schedule-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 15px;
            margin-bottom: 8px;
            background: #f8f9ff;
            border-radius: 10px;
            border-left: 4px solid #667eea;
        }
        .schedule-time {
            font-weight: 600;
            color: #666;
        }
        .schedule-subject {
            font-weight: 700;
            color: #333;
        }

        /* 详细课表样式 (原始仪表盘) */
        .flow-grid {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .flow-row {
            display: grid;
            grid-template-columns: 90px 1fr 70px;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            border-radius: 12px;
            background: white;
            box-shadow: 0 2px 4px rgba(0,20,40,0.04);
            transition: all 0.2s;
            border: 1px solid #e8ecf4;
        }
        .flow-row.current {
            border: 2px solid #2563eb;
            background: #ecf3ff;
            transform: scale(1.01);
            box-shadow: 0 4px 12px rgba(37,99,235,0.15);
        }
        .flow-row.completed {
            opacity: 0.6;
            background: #f5f7fa;
        }
        .flow-row.completed .flow-task {
            text-decoration: line-through;
            color: #999;
        }
        .flow-time {
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.95rem;
            color: #0b2c5f;
        }
        .flow-task {
            font-weight: 600;
            font-size: 1rem;
            color: #1e2f50;
        }
        .flow-task-desc {
            font-size: 0.8rem;
            color: #666;
            margin-top: 3px;
        }
        .flow-tag {
            justify-self: end;
            background: #e2e9ff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #2d4680;
            text-align: center;
        }
        .flow-tag.exercise {
            background: #c3f0d6;
            color: #0b5432;
        }
        .flow-tag.rest {
            background: #f0d6e8;
            color: #6b2d5c;
        }
        .flow-tag.daily {
            background: #e8e8e8;
            color: #555;
        }

        /* 状态指示灯 */
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
        }
        .status-online { background: #38ef7d; }
        .status-offline { background: #f5576c; }

        /* 底部 */
        .footer {
            background: white;
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            color: #666;
        }

        /* 时钟 */
        .clock {
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            color: #667eea;
            font-family: 'JetBrains Mono', monospace;
            margin: 20px 0;
        }

        /* 进度条 */
        .progress-bar {
            height: 10px;
            background: #f0f3ff;
            border-radius: 5px;
            overflow: hidden;
            margin: 15px 0;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.3s;
        }
    </style>
</head>
<body>
    <!-- 登录页面 -->
    <div id="loginPage">
        <div class="login-card">
            <h1 class="login-title">高考学习系统</h1>
            <div class="login-tabs">
                <div class="login-tab active" onclick="switchTab('login')">登录</div>
                <div class="login-tab" onclick="switchTab('register')">注册</div>
            </div>

            <div id="loginMessage" class="login-message"></div>

            <form id="loginForm" class="login-form" onsubmit="handleLogin(event)">
                <input type="text" id="loginUsername" placeholder="用户名" required autocomplete="username">
                <input type="password" id="loginPassword" placeholder="密码" required autocomplete="current-password">
                <button type="submit" class="login-btn" id="loginBtn">登录</button>
            </form>

            <form id="registerForm" class="login-form" style="display: none;" onsubmit="handleRegister(event)">
                <input type="text" id="regUsername" placeholder="用户名（至少 3 个字符）" required minlength="3" autocomplete="username">
                <input type="email" id="regEmail" placeholder="邮箱（可选）" autocomplete="email">
                <input type="password" id="regPassword" placeholder="密码（至少 6 个字符）" required minlength="6" autocomplete="new-password">
                <input type="password" id="regConfirm" placeholder="确认密码" required autocomplete="new-password">
                <input type="text" id="regInviteCode" placeholder="邀请码（必填）" required autocomplete="off">
                <button type="submit" class="login-btn" id="registerBtn">注册（赠送 30 天 VIP）</button>
                <p class="login-tip">注册即送 30 天 VIP 体验</p>
            </form>
        </div>
    </div>

    <!-- 用户信息卡片（未登录时显示在 header 处） -->
    <div id="userInfoCard" class="user-info-card" style="display: none;">
        <div class="user-avatar">👤</div>
        <div class="user-name" id="displayUsername">用户名</div>
        <div class="user-email" id="displayEmail">email@example.com</div>
        <div class="user-vip" id="displayVip">VIP0</div>
        <button class="logout-btn" onclick="handleLogout()">退出登录</button>
    </div>

    <div class="container" id="mainContainer" style="display: none;">
        <!-- 头部 -->
        <div class="header">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h1>🎓 高考学习系统</h1>
                <div id="headerUserStatus" style="display: none; align-items: center; gap: 12px;">
                    <span class="header-badge" id="headerUsername">用户名</span>
                    <span class="header-badge" id="headerVip">VIP0</span>
                    <button onclick="handleLogout()" style="padding: 6px 12px; background: #ff4d4f; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 12px;">退出</button>
                </div>
            </div>
            <div class="header-info">
                <span class="header-badge">🎯 目标：540 分</span>
                <span class="header-badge">📊 当前：376 分</span>
                <span class="header-badge">⏰ 倒计时：<span id="countdown">90</span>天</span>
                <span class="header-badge" id="dayTypeBadge">单日·数学</span>
            </div>

            <!-- 实时时钟 -->
            <div class="clock" id="clock">00:00:00</div>
        </div>

        <!-- 主网格 -->
        <div class="dashboard-grid">
            <!-- 当前任务 -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">📚 当前学习任务</span>
                    <span><span class="status-dot status-online"></span>实时</span>
                </div>
                <div class="card-body">
                    <div class="current-task" id="currentTask">
                        <div class="current-task-label">正在进行</div>
                        <div class="current-task-name">加载中...</div>
                        <div class="current-task-time">--:-- - --:--</div>
                    </div>
                    <div class="current-task" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                        <div class="current-task-label">接下来</div>
                        <div class="current-task-name" id="nextTask">加载中...</div>
                        <div class="current-task-time" id="nextTime">--:--</div>
                    </div>
                </div>
            </div>

            <!-- 学习统计 + 快速操作 -->
            <div class="card" style="grid-column: span 2;">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <span class="card-title">📊 学习统计</span>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <button class="btn btn-primary" onclick="openMistakeSystem()" style="padding: 8px 16px; font-size: 0.9rem;">
                            🖥️ 错题系统
                        </button>
                        <a href="/tools" target="_blank" class="btn" style="padding: 8px 16px; font-size: 0.9rem; background: linear-gradient(135deg, #667eea, #764ba2); color: white; text-decoration: none;">
                            🛠️ 工具中心
                        </a>
                        <button class="btn btn-warning" onclick="startFocusMode()" style="padding: 8px 16px; font-size: 0.9rem;">
                            🧘 专注模式
                        </button>
                        <a href="schedule-view.html" target="_blank" class="btn" style="padding: 8px 16px; font-size: 0.9rem; background: linear-gradient(135deg, #11998e, #38ef7d); color: white; text-decoration: none;">
                            📅 本周日程
                        </a>
                        <a href="schedule-editor.html" target="_blank" class="btn" style="padding: 8px 16px; font-size: 0.9rem; background: linear-gradient(135deg, #ff9966, #ff5e62); color: white; text-decoration: none;">
                            📝 编辑时间表
                        </a>
                        <button onclick="openWordcardSystem()" class="btn" style="padding: 8px 16px; font-size: 0.9rem; background: linear-gradient(135deg, #4b6cb7, #182848); color: white; text-decoration: none; border: none; cursor: pointer;">
                            🃏 单词卡片
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="stats-row">
                        <div class="stat-item">
                            <div class="stat-value" id="studyMinutes">0</div>
                            <div class="stat-label">今日学习 (分钟)</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value" id="mistakeCount">0</div>
                            <div class="stat-label">错题总数</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value" id="todayMistakes">0</div>
                            <div class="stat-label">今日新增</div>
                        </div>
                    </div>
                    <div style="margin-top: 20px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <span>今日目标完成度</span>
                            <span id="progressText">0%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="progressBar" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 监控画面 -->
            <div class="card" id="monitorCard" style="grid-column: 1 / -1; display: none;">
                <div class="card-header">
                    <span class="card-title">📹 <span id="monitorName">监控摄像头</span></span>
                    <span><span class="status-dot status-online"></span>直播</span>
                </div>
                <div class="card-body" style="padding: 0; background: #000; display: flex; align-items: center; justify-content: center;">
                    <iframe id="monitorFrame" src="" style="width: 100%; height: 400px; border: none;" allowfullscreen></iframe>
                </div>
            </div>

            <!-- 今日课表 -->
            <div class="card" style="grid-column: 1 / -1;">
                <div class="card-header">
                    <span class="card-title">📋 今日课表</span>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <span class="header-badge" id="dayTypeBadge">单日</span>
                        <span class="header-badge" id="weekTypeBadge">单周</span>
                    </div>
                </div>
                <div class="card-body" id="scheduleList">
                    <div style="text-align: center; color: #999; padding: 40px;">
                        加载课表中...
                    </div>
                </div>
            </div>
        </div>

        <!-- 底部 -->
        <div class="footer">
            <p>高考学习系统 v2.0 | 距离 2026 年高考还有 <strong id="footerCountdown">90</strong> 天</p>
            <p style="margin-top: 10px; font-size: 0.9rem;">
                API 状态：<span id="apiStatus">检测中...</span>
            </p>
        </div>
    </div>

    <script>
        // 动态获取 API 基础地址（统一 API 端口 8080）
        // 检测是否在Electron环境中
        const isElectron = typeof window !== 'undefined' && window.process && window.process.type;

        let ACCOUNT_API_BASE, API_BASE, MISTAKE_SYSTEM_URL;

        if (isElectron) {
            // 在Electron环境中，使用本地服务器地址
            ACCOUNT_API_BASE = 'http://localhost:8080/account';
            API_BASE = 'http://localhost:8080';
            MISTAKE_SYSTEM_URL = 'http://localhost:8080/mistake/';
        } else {
            // 在浏览器环境中，使用相对路径（通过 Nginx 反向代理）
            ACCOUNT_API_BASE = '/account';
            API_BASE = '';
            MISTAKE_SYSTEM_URL = '/mistake/';
        }

        // 解析 URL 参数
        const urlParams = new URLSearchParams(window.location.search);
        const needLogin = urlParams.get('needLogin') === '1';
        const returnUrl = urlParams.get('returnUrl') || '';

        // ============ 登录验证相关 ============
        let currentUser = null;

        // 检查登录状态（移除SSO机制，基于本地存储的用户信息）
        function checkLoginStatus() {
            const userInfo = localStorage.getItem('user_info');

            if (userInfo) {
                try {
                    currentUser = JSON.parse(userInfo);
                    // 如果有返回地址，直接跳转回去
                    if (returnUrl) {
                        window.location.href = decodeURIComponent(returnUrl);
                        return;
                    }
                    showMainPage();
                } catch (e) {
                    console.error('解析用户信息失败:', e);
                    showLoginPage();
                }
            } else {
                showLoginPage();
            }
        }

        // 验证 token（移除SSO机制，现在简化处理）
        async function verifyToken(token) {
            try {
                // 由于移除了SSO机制，现在直接检查账号服务器状态
                const response = await fetch(`${ACCOUNT_API_BASE}/api/verify`);
                const result = await response.json();
                if (result.valid) {
                    currentUser = result.user;
                    showMainPage();
                } else {
                    logout();
                }
            } catch (error) {
                console.error('验证登录状态失败:', error);
                // 如果账号服务器不可用，允许离线使用
                showMainPage();
            }
        }

        // 显示登录页面
        function showLoginPage() {
            document.getElementById('loginPage').classList.add('active');
            document.getElementById('mainContainer').style.display = 'none';
        }

        // 显示主页面
        function showMainPage() {
            document.getElementById('loginPage').classList.remove('active');
            document.getElementById('mainContainer').style.display = 'block';
            updateUserDisplay();
            loadData();
        }

        // 更新用户显示
        function updateUserDisplay() {
            if (currentUser) {
                // 更新登录卡片中的用户信息
                const displayCard = document.getElementById('userInfoCard');
                if (displayCard) {
                    document.getElementById('displayUsername').textContent = currentUser.username;
                    document.getElementById('displayEmail').textContent = currentUser.email || '未设置邮箱';
                    document.getElementById('displayVip').textContent = `VIP${currentUser.vip_level}`;
                }
                // 更新 header 中的用户状态
                const headerStatus = document.getElementById('headerUserStatus');
