# 高考错题系统 - 前端环境配置
# 将此文件复制为 .env.production 并修改配置

# 生产环境API基础URL
VITE_API_BASE_URL="https://your-backend-domain.com/api"
VITE_ACCOUNT_API_URL="https://your-backend-domain.com/account"

# API超时时间（毫秒）
VITE_API_TIMEOUT=30000

# API重试次数
VITE_API_RETRY_ATTEMPTS=3

# 是否启用调试模式
VITE_DEBUG_MODE=false

# CDN基础路径（如果使用CDN部署）
VITE_CDN_BASE_PATH=""